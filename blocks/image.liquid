<img 
  src="{{ block.settings.image | image_url: width: 1500 }}" 
  srcset="{{ block.settings.image | image_url: width: 165 }} 165w, 
          {{ block.settings.image | image_url: width: 360 }} 360w, 
          {{ block.settings.image | image_url: width: 535 }} 535w, 
          {{ block.settings.image | image_url: width: 750 }} 750w, 
          {{ block.settings.image | image_url: width: 1070 }} 1070w, 
          {{ block.settings.image | image_url: width: 1500 }} 1500w" 
        class="{{ block.settings.position_type }}" 
        width="1500" 
        height="556" 
        loading="lazy" 
        style="top: {{ block.settings.top_offset }}%;  left: {{ block.settings.left_offset }}%;">
{% schema %}
    {
        "name": "Image",
        "settings": [
            {
                "type": "image_picker",
                "id": "image",
                "label": "Image"
            }
        ],
        "presets": [
            {
                "name": "Image"
            }
        ]
    }
{% endschema %}