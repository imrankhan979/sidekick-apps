
{%- style -%}
    .block-{{ block.id }}-padding {
      padding-top: {{ block.settings.padding_vertical | times: 0.45 | round: 0 }}px;
      padding-bottom: {{ block.settings.padding_vertical | times: 0.45 | round: 0 }}px;
      padding-left: {{ block.settings.padding_horizontal | times: 0.40 | round: 0 }}px;
      padding-right: {{ block.settings.padding_horizontal | times: 0.40 | round: 0 }}px;
    }
  
    @media screen and (min-width: 991px) {
      .block-{{ block.id }}-padding {
        padding-top: {{ block.settings.padding_vertical }}px;
        padding-bottom: {{ block.settings.padding_vertical }}px;
        padding-left: {{ block.settings.padding_horizontal }}px;
        padding-right: {{ block.settings.padding_horizontal }}px;
      }
    }
    @media screen and (min-width: 991px) {
      .block-{{ block.id }}-padding {
        padding-top: {{ block.settings.padding_vertical }}px;
        padding-bottom: {{ block.settings.padding_vertical }}px;
        padding-left: {{ block.settings.padding_horizontal }}px;
        padding-right: {{ block.settings.padding_horizontal }}px;
      }
    }
    .block-{{ block.id }}-margin {
      margin-top: {{ block.settings.margin_top | times: 0.50 | round: 0 }}px;
      margin-bottom: {{ block.settings.margin_bottom | times: 0.50 | round: 0 }}px;
    }
  
    @media screen and (min-width: 991px) {
      .block-{{ block.id }}-margin {
        margin-top: {{ block.settings.margin_top }}px;
        margin-bottom: {{ block.settings.margin_bottom }}px;    
      }
    }
    #shopify-block-{{ block.id }}{
        position: relative;
      }
    @media screen and (min-width: 767px) {
      #shopify-block-{{ block.id }}{
        max-width: {{ block.settings.max_width }}%;
      }
    }
  {%- endstyle -%}

<div class="block-{{ block.id }} color-{{ block.settings.section_color_scheme }} block-{{ block.id }}-padding block-{{ block.id }}-margin {% if block.settings.inner_gap %}inner-gap{% endif %} {{ block.settings.position_type }}" style="transform: rotate({{ block.settings.card_rotation }}deg)">
    {% content_for 'blocks' %}
</div>

{% schema %}
    {
  "name": "t:blocks.group.name",
  "class": "block-group",
  "blocks": [
    { "type": "@theme" }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "inner_gap",
      "label": "t:blocks.group.settings.inner_gap.label",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:blocks.group.settings.max_width.label",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_rotation",
      "min": -45,
      "max": 45,
      "step": 1,
      "unit": "°",
      "label": "t:blocks.group.settings.card_rotation.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:blocks.group.settings.header_padding.label"
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:blocks.group.settings.padding_horizontal.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:blocks.group.settings.padding_vertical.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:blocks.group.settings.header_margin.label"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:blocks.group.name"
    }
  ]
}
{% endschema %}