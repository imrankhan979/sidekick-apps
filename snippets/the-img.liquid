{% comment %}
  the-img
  Accepts:
  - image: {Object} image
  Usage:
  {% render 'the-img' %}
{% endcomment %}

{%- if image -%}
  {%- liquid
    assign height = image.width | divided_by: image.aspect_ratio | round
    assign sizes = '100vw'
    assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
  -%}
  {{
    image
    | image_url: width: 3840
    | image_tag: height: height, sizes: sizes, widths: widths, loading: 'lazy', rel: 'preload', alt: image.alt
  }}
{%- endif -%}
