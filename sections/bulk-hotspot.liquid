{{ 'image-hotspot.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bulk-hotspot-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
    <div class="page-width">
       <div class="bulk_hotspot_wrapper">
          <div class="bulk_hotspot_left_content">
                {% if section.settings.section_title != blank%}
                    <h2 class="bulk_hotspot_title">{{ section.settings.section_title }}</h2>
                {% endif %}
             <div class="bulk_hotspot_left_text">
                {% if section.settings.hotspot_title != blank %}
                    <h5 class="hotspot_title">{{ section.settings.hotspot_title }}</h5>
                {% endif %}
                {% if section.settings.hotspot_subtitle != blank %}
                    <span class="hotspot_sub_title">{{ section.settings.hotspot_subtitle }}</span>
                    
                {% endif %}
                <span class="hotspot_percent">Subtotal: <strong>$668.00</strong> </span>
                <div class="bulk_hotspot_button">
                   <button class="bulk-hotspot-btn">{{ section.settings.cart_button_text }} <span>
                    {{- 'icon-plus.svg' | inline_asset_content -}}
                      </span></button>
                </div>
             </div>
          </div>
          <div class="bulk_hotspot_box bulk_hotspot_slider">
             <div class="bulk_hotspot_images">
                {% if section.settings.hotsopt_image != blank %}
                    {{ section.settings.hotsopt_image | image_url: width: 1500 | image_tag: widths: '165, 360, 535, 750, 1070, 1500' }}
                    {% else %}
                            {{ 'detailed-apparel-1'  | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
                <!-- Hotspots --> 
                {% for block in section.blocks %}
                    {% if block.type == 'product' %}
                            <div class="hotspot {% if forloop.first %} active{% endif %}" data-slide="{{forloop.index}}" style="top: {{ block.settings.pointer_position_top }}%; left: {{ block.settings.pointer_position_left }}%;"
                               data-content="">
                               <div class="popup-wrapper">
                                   <div class="hotspot-popup">
                                    {% if block.settings.selected_product.title != blank %}
                                        <p>{{ block.settings.selected_product.title }}</p>
                                        {% else %}
                                            <p>Product title</p>
                                    {% endif %}
                                    {% if block.settings.selected_product.price != blank %}
                                        <p>{{ block.settings.selected_product.price |  money }}</p>
                                        {% else %}
                                            <p>{{ 00.00 |  money }}</p>
                                    {% endif %}
                                   </div>
                               </div>
                            </div>
                    {% endif %}
                 {% endfor %}

             </div>
             
             <!-- Flickity Slider -->

             <div class="hotpot_slider_wrapper"
             data-flickity='{"contain": true, "prevNextButtons": true, "pageDots": true }'>
             {% for block in section.blocks %}
                {% if block.type == 'product' %}
                    <div class="hotpot_slider_item">
                       <div class="hotpot_slider_thumb">
                        {% assign product = block.settings.selected_product %}
                            <a class="flex" href="{{ product.url }}">
                                {% if product.featured_image != blank %}
                                    {{ product.featured_image | image_url: width: 1500 | image_tag: widths: '165, 360, 535, 750, 1070, 1500' }}
                                    {% else %}
                                    {{ 'product-apparel-1'  | placeholder_svg_tag: 'placeholder-svg' }}
                                {% endif %}
                            </a>
                            <div class="hotpot_slider_content">
                                {% if product.vendor != blank %}
                                    <span class="hotpot_slider_label">{{ product.vendor }}</span>
                                {% endif %}
                                {% if product.title != blank %}
                                    <h5><a class="hotpot_slider_title" href="{{product.url}}">{{ product.title }}</a></h5>
                                    {% else %}
                                    <h5><a class="hotpot_slider_title" href="{{product.url}}">Product title</a></h5>
                                {% endif %}
                                {% if product.price != blank %}
                                    <span class="hotpot_slider_amount">{{ product.price |  money }}</span>
                                {% endif %}

                                {% assign swatchAvailable = false %}
                                {% for option in product.options_with_values %}
                                    {% if option.name == 'Color' %}
                                        {% assign swatchAvailable = true %}
                                    {% endif %}
                                {% endfor %}

                                {% if swatchAvailable %}
                                    {% if product.variants.size > 1 %}
                                        <div class="variant-picker">
                                        {% for option in product.options_with_values %}
                                            {% if option.name == 'Color' %}
                                            <div class="variant-group color-swatch">
                                                <div class="variant-items">
                                                {% for value in option.values %}
                                                    {% assign variant_available = false %}
                                                    {% for variant in product.variants %}
                                                    {% if variant.available and variant.options contains value %}
                                                        {% assign variant_available = true %}
                                                    {% endif %}
                                                    {% endfor %}
                                                    {%- liquid 
                                                    assign swatch_value = null
                                                    if value.swatch.image
                                                        assign image_url = value.swatch.image | image_url: width: 50
                                                        assign swatch_value = 'url(' | append: image_url | append: ')'
                                                    elsif value.swatch.color
                                                        assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                                                    endif
                                                    -%}
                                                    <input id="{{ product.id }}-{{ value }}" 
                                                        type="radio" 
                                                        name="option-{{ product.id }}-{{ option.name | handleize }}" 
                                                        value="{{ value }}" 
                                                        data-option-index="{{ forloop.parentloop.index0 }}" 
                                                        data-value="{{ value }}" 
                                                        data-product-id="{{ product.id }}" 
                                                        {% unless variant_available %}disabled{% endunless %}  
                                                        style="--swatch-bg: {{ swatch_value }}">
                                                        <label for="{{ product.id }}-{{ value }}" style="--swatch-bg: {{ swatch_value }}"></label>
                                                {% endfor %}
                                                </div>
                                            </div>
                                            {% endif %}
                                        {% endfor %}
                                        </div>
                                    {% endif %}                                  
                                {% endif %}
                            </div>
                       </div>
                    </div>
                {% endif %}
             {% endfor %}
             </div>
          </div>
       </div>
    </div>
</section>
 
 <script>
document.addEventListener("DOMContentLoaded", () => {
    function initSlider() {
        const sliderWrapper = document.querySelector(".hotpot_slider_wrapper");
        if (!sliderWrapper) return;
        const flkty = new Flickity(sliderWrapper, {
            contain: true,
            prevNextButtons: true,
            pageDots: false
        });
        const hotspots = document.querySelectorAll(".hotspot");
        const updateActiveHotspot = (index) => {
            hotspots.forEach((hotspot, i) => 
                hotspot.classList.toggle("active", i === index)
            );
        };
        hotspots.forEach((hotspot, index) => {
            hotspot.addEventListener("click", () => {
                flkty.select(index);
                updateActiveHotspot(index);
            });
        });
        flkty.on("change", updateActiveHotspot);
        updateActiveHotspot(0);
    }
    initSlider(); // Run on page load
    // Reinitialize when the section updates in the Shopify editor
    document.addEventListener("shopify:section:load", initSlider);
});

 </script>

{% schema %}
{
  "name": "Image hotspot",
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
        "type": "text",
        "id": "section_title",
        "label": "Section title",
        "default": "Your next favorite outfit"
    },
    {
        "type": "text",
        "id": "hotspot_title",
        "label": "Hotspot title",
        "default": "Editor’s Picked Look"
    },
    {
        "type": "text",
        "id": "hotspot_subtitle",
        "label": "Hotspot subtitle",
        "default": "Including 3 Items: Shirt, T-Shirt, Pant"
    },
    {
        "type": "text",
        "id": "cart_button_text",
        "label": "Cart button text",
        "default": "ADD ALL TO CART"
    },
    {
        "type": "image_picker",
         "id": "hotsopt_image",
         "label": "Hotspot image"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 120
    }
  ],
  "blocks": [
    {
        "type": "product",
        "name":  "Product",
        "settings": [
            {
                "type": "product",
                "label": "Choose product",
                "id": "selected_product"
            },
            {
                "type": "header",
                "content": "Hotspot point position"
            },
            {
            "type": "range",
            "id": "pointer_position_top",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Top",
            "default": 0
        },
        {
            "type": "range",
            "id": "pointer_position_left",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Left",
            "default": 0
        }
        ]
    }
  ],
  "presets": [
    {
      "name": "Image hotspot",
      "blocks": [
        {
            "type": "product",
          "settings": {
            "selected_product": "",
            "pointer_position_top": 18,
            "pointer_position_left": 28
          }
        },
        {
            "type": "product",
          "settings": {
            "selected_product": "",
            "pointer_position_top": 42,
            "pointer_position_left": 56
          }
        },
        {
            "type": "product",
          "settings": {
            "selected_product": "",
            "pointer_position_top": 85,
            "pointer_position_left": 45
          }
        }
      ]
    }
  ]
}
{% endschema %}
