{% schema %}
    {
      "name": "Multi-product add",
      "settings": [],
      "blocks": [
        {
          "type": "product",
          "name": "Product",
          "settings": [
            {
              "type": "product",
              "id": "product",
              "label": "Select product"
            },
            {
              "type": "number",
              "id": "quantity",
              "label": "Default quantity",
              "default": 1
            }
          ]
        }
      ],
      "presets": [
        {
          "name": "Multi-product add"
        }
      ]
    }
    {% endschema %}
    
    <div class="product-selection">
    
         <div class="products-bundels">
      {% for block in section.blocks %}
        
        {% if block.type == 'product' and block.settings.product %}
          {% assign product = all_products[block.settings.product] %}
          {% if product %}
             {% if forloop.first == false %}
                <span class="operator">+</span>
              {% endif %}
            
            <div 
              class="product-item" 
              data-id="{{ product.variants.first.id }}" 
              data-quantity="{{ block.settings.quantity }}" 
              data-price="{{ product.price }}" 
              data-compare-price="{{ product.compare_at_price }}">
             <img src="{{ product.featured_image | image_url }}" alt="{{ product.title }}" width="200px" height="200px" />
              <h3>{{ product.title }}</h3>
              <p>
                <span class="price">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="compare-price"><del>{{ product.compare_at_price | money }}</del></span>
                {% endif %}
              </p>
              <label>
                <input type="checkbox" class="product-checkbox" Checked />
                Select
              </label>
            </div>
          {% else %}
            <p>Selected product is unavailable or invalid.</p>
          {% endif %}
        {% endif %}
      {% endfor %}
            <span class="operator">=</span>
             <div id="total-selected-price">Total Selected Price: $0.00</div>
         </div>
     
      <button id="add-all-to-cart-btn" disabled>Add Selected to Cart</button>
    </div>
    
     
    
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const addToCartButton = document.getElementById("add-all-to-cart-btn");
        const checkboxes = document.querySelectorAll(".product-checkbox");
        const totalPriceElement = document.getElementById("total-selected-price");
    
        /**
         * Enable or disable the add-to-cart button based on selection
         */
        function updateButtonState() {
          const anyChecked = Array.from(checkboxes).some((checkbox) => checkbox.checked);
          addToCartButton.disabled = !anyChecked;
        }
    
        /**
         * Calculate and update the total discounted price and savings
         */
        function updateTotalPrice() {
          let totalDiscountedPrice = 0;
          let totalSavings = 0;
    
          document.querySelectorAll(".product-item").forEach((productItem) => {
            const checkbox = productItem.querySelector(".product-checkbox");
            if (checkbox.checked) {
              const price = parseFloat(productItem.dataset.price) / 100; // Discounted price
              const comparePrice = parseFloat(productItem.dataset.comparePrice || 0) / 100; // Regular price
              const quantity = parseInt(productItem.dataset.quantity) || 1;
    
              totalDiscountedPrice += price * quantity;
    
              // If comparePrice exists, calculate savings
              if (comparePrice > 0 && comparePrice > price) {
                totalSavings += (comparePrice - price) * quantity;
              }
            }
          });
    
          totalPriceElement.innerHTML = `
            Total Price: $${totalDiscountedPrice.toFixed(2)}<br>
            <span class="total-savings">Total Savings: $${totalSavings.toFixed(2)}</span>
          `;
        }
    
        /**
         * Extract selected product data for the bulk add-to-cart action
         */
        function extractSelectedProducts() {
          const selectedProducts = [];
          document.querySelectorAll(".product-item").forEach((productItem) => {
            const checkbox = productItem.querySelector(".product-checkbox");
            if (checkbox.checked) {
              const id = productItem.dataset.id;
              const quantity = productItem.dataset.quantity || 1;
              selectedProducts.push({ id: parseInt(id), quantity: parseInt(quantity) });
            }
          });
          return selectedProducts;
        }
    
        /**
         * Perform the bulk add-to-cart action
         */
        async function handleBulkAddToCart() {
          const selectedProducts = extractSelectedProducts();
    
          if (selectedProducts.length === 0) {
            alert("Please select at least one product.");
            return;
          }
    
          const requestBody = { items: selectedProducts };
    
          try {
            // Add products to cart
            await fetch(`${window.Shopify.routes.root}cart/add.js`, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(requestBody),
            });
    
            // Navigate to the cart page
            window.location.href = "/cart";
          } catch (error) {
            console.error("Error adding products to cart:", error);
            alert("An error occurred. Please try again.");
          }
        }
    
        // Attach event listeners
        checkboxes.forEach((checkbox) => {
          checkbox.addEventListener("change", () => {
            updateButtonState();
            updateTotalPrice();
          });
        });
    
        addToCartButton.addEventListener("click", (e) => {
          e.preventDefault();
          handleBulkAddToCart();
        });
    
        // Initialize button state and total price on page load
        updateButtonState();
        updateTotalPrice();
      });
    </script>
    
    
    
    <style>
    body {
      font-family: Arial, sans-serif;
      margin: 20px;
      background-color: #f9f9f9;
    }
    .products-bundels {
       display: flex
    ; 
        align-items: center; 
    }
    .product-selection {
      background-color: #fff;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    }
    
    #total-selected-price {
      margin-bottom: 20px;
      font-size: 18px;
      font-weight: bold;
      color: #333;
    }
    
    .product-item {
      text-align: center;
      margin: 0 10px 20px;
    }
    
    .product-item h3 {
      font-size: 16px;
      color: #333;
      margin-bottom: 10px;
    }
    
    .product-item img {
      width: 80px;
      height: 120px;
      object-fit: cover;
      border-radius: 4px;
      margin-bottom: 10px;
    }
    
    .product-item p {
      font-size: 14px;
      color: #333;
      margin: 5px 0;
    }
    
    .product-item .price {
      font-size: 14px;
    }
    
    .product-item .compare-price {
      text-decoration: line-through;
      color: #e53935;
      margin-left: 5px;
    }
    
    .product-item label {
      display: block;
      margin-top: 10px;
      font-size: 14px;
      color: #333;
    }
    
    .product-item input.product-checkbox {
      margin-right: 5px;
    }
    
    #add-all-to-cart-btn {
      display: block;
      margin: 20px auto 0;
      padding: 10px 20px;
      background-color: #00bcd4;
      color: #fff;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 14px;
    }
    
    #add-all-to-cart-btn:hover {
      background-color: #0097a7;
    }
    .total-savings {
        color: #33c24d;
    }
    </style>
    