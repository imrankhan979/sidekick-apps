{% doc %}
  @prompt
    Create an urgent promotional hero banner section for the homepage with the following elements:- A bold main headline for a limited-time offer (e.g., "50% Off — Today Only!")- An urgency subtext line (e.g., "Ends Friday at Midnight • While Supplies Last")- A one-sentence subheading reinforcing the offer- A high-contrast CTA button with bold action text (e.g., "Shop Sale Now")- A background supporting an image or bold red/orange gradient- A countdown-style urgency badge or fire/lightning icon- Contrasting colors, bold typography, large font sizes- All text fields customizable in the theme editor
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-urgent-hero-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin: 0 auto;
  }

  .ai-urgent-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-urgent-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-urgent-hero-gradient-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      {{ block.settings.gradient_direction }}deg,
      {{ block.settings.gradient_color_1 }},
      {{ block.settings.gradient_color_2 }}
    );
  }

  .ai-urgent-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-urgent-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.content_padding }}px;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-urgent-hero-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }

  .ai-urgent-hero-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.badge_icon_size }}px;
    height: {{ block.settings.badge_icon_size }}px;
    flex-shrink: 0;
  }

  .ai-urgent-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_font_size }}px;
    font-weight: 900;
    color: {{ block.settings.headline_color }};
    line-height: 1.1;
    margin: 0 0 16px 0;
    text-transform: uppercase;
    letter-spacing: -1px;
  }

  .ai-urgent-hero-urgency-{{ ai_gen_id }} {
    font-size: {{ block.settings.urgency_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.urgency_color }};
    margin: 0 0 20px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-urgent-hero-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_font_size }}px;
    font-weight: 400;
    color: {{ block.settings.subheading_color }};
    line-height: 1.5;
    margin: 0 0 32px 0;
  }

  .ai-urgent-hero-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 700;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-urgent-hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-urgent-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-urgent-hero-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
    }

    .ai-urgent-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_font_size | times: 0.6 }}px;
    }

    .ai-urgent-hero-urgency-{{ ai_gen_id }} {
      font-size: {{ block.settings.urgency_font_size | times: 0.7 }}px;
    }

    .ai-urgent-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_font_size | times: 0.8 }}px;
    }

    .ai-urgent-hero-badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size | times: 0.8 }}px;
    }

    .ai-urgent-hero-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-urgent-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-urgent-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_image != blank %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-urgent-hero-gradient-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>

  {% if block.settings.show_overlay %}
    <div class="ai-urgent-hero-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-urgent-hero-content-{{ ai_gen_id }}">
    {% if block.settings.show_badge %}
      <div class="ai-urgent-hero-badge-{{ ai_gen_id }}">
        {% if block.settings.badge_icon == 'fire' %}
          <svg class="ai-urgent-hero-badge-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 23C7.589 23 4 19.411 4 15c0-3.518 2.614-6.432 6-6.92V6c0-.552.448-1 1-1s1 .448 1 1v2.08c3.386.488 6 3.402 6 6.92 0 4.411-3.589 8-8 8zm0-14c-3.309 0-6 2.691-6 6s2.691 6 6 6 6-2.691 6-6-2.691-6-6-6zm0 10c-1.654 0-3-1.346-3-3 0-1.403.974-2.58 2.281-2.899.414-.101.719.312.719.719v.18c0 1.654 1.346 3 3 3 .407 0 .82-.319.719-.719C15.58 14.974 14.403 14 13 14c-1.654 0-3 1.346-3 3s1.346 3 3 3c.552 0 1-.448 1-1s-.448-1-1-1z"/>
          </svg>
        {% elsif block.settings.badge_icon == 'lightning' %}
          <svg class="ai-urgent-hero-badge-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor">
            <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
          </svg>
        {% elsif block.settings.badge_icon == 'clock' %}
          <svg class="ai-urgent-hero-badge-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zm0 18c-4.411 0-8-3.589-8-8s3.589-8 8-8 8 3.589 8 8-3.589 8-8 8z"/>
            <path d="M13 7h-2v6h6v-2h-4z"/>
          </svg>
        {% endif %}
        {{ block.settings.badge_text }}
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h1 class="ai-urgent-hero-headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.urgency_text != blank %}
      <p class="ai-urgent-hero-urgency-{{ ai_gen_id }}">
        {{ block.settings.urgency_text }}
      </p>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-urgent-hero-subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-urgent-hero-cta-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Urgent promo hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height (desktop)",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Minimum height (mobile)",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding (desktop)",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_padding_mobile",
      "label": "Content padding (mobile)",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#d93434"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#ff6b35"
    },
    {
      "type": "range",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "min": 0,
      "max": 360,
      "step": 45,
      "unit": "deg",
      "default": 135
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Urgency badge"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show urgency badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Limited Time"
    },
    {
      "type": "select",
      "id": "badge_icon",
      "label": "Badge icon",
      "options": [
        {
          "value": "fire",
          "label": "Fire"
        },
        {
          "value": "lightning",
          "label": "Lightning"
        },
        {
          "value": "clock",
          "label": "Clock"
        }
      ],
      "default": "fire"
    },
    {
      "type": "range",
      "id": "badge_icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Background color",
      "default": "#ffec3e"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "badge_padding_vertical",
      "label": "Vertical padding",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "badge_padding_horizontal",
      "label": "Horizontal padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "50% Off — Today Only!"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "headline_font_size",
      "label": "Font size",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "header",
      "content": "Urgency text"
    },
    {
      "type": "text",
      "id": "urgency_text",
      "label": "Urgency text",
      "default": "Ends Friday at Midnight • While Supplies Last"
    },
    {
      "type": "color",
      "id": "urgency_color",
      "label": "Color",
      "default": "#ffec3e"
    },
    {
      "type": "range",
      "id": "urgency_font_size",
      "label": "Font size",
      "min": 12,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Don't miss out on our biggest sale of the year. Shop now and save big on all your favorites!"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Font size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
