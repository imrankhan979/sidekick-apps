{% doc %}
  @prompt
    Create a customer testimonials grid section with the following features:- Section title (editable, e.g. "What Our Customers Say")- Filter options: filter by star rating (5★, 4★ ), product, and date (newest first)- Grid layout showing 6-12 review cards, each containing:  - Customer name and avatar  - Star rating display  - Optional review title  - Review text (2-4 sentences)  - Verified purchase badge  - Optional helpful vote counter- Pagination or Load More button to show additional reviews- Sorting options: Newest, Most Helpful, Highest Rating- Clean, readable design that builds trust through transparent customer feedback
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-grid-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-testimonials-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-testimonials-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 20px;
  }

  .ai-testimonials-filters-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    align-items: center;
    margin-bottom: 30px;
  }

  .ai-testimonials-filter-group-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .ai-testimonials-filter-label-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-testimonials-filter-select-{{ ai_gen_id }} {
    padding: 8px 12px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_background }};
    color: {{ block.settings.text_color }};
    font-size: 14px;
    cursor: pointer;
  }

  .ai-testimonials-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 40px;
  }

  .ai-testimonials-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-testimonials-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-testimonials-card-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-testimonials-card-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-testimonials-avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ block.settings.avatar_bg_color }};
    color: {{ block.settings.avatar_text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 18px;
    flex-shrink: 0;
  }

  .ai-testimonials-customer-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-testimonials-customer-name-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px;
  }

  .ai-testimonials-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-testimonials-star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 16px;
  }

  .ai-testimonials-star-{{ ai_gen_id }}.empty {
    color: {{ block.settings.star_empty_color }};
  }

  .ai-testimonials-review-title-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 15px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-testimonials-review-text-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-testimonials-card-footer-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 12px;
    border-top: 1px solid {{ block.settings.border_color }};
  }

  .ai-testimonials-verified-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: {{ block.settings.verified_color }};
    font-weight: 600;
  }

  .ai-testimonials-verified-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
  }

  .ai-testimonials-helpful-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: {{ block.settings.text_color }};
  }

  .ai-testimonials-helpful-button-{{ ai_gen_id }} {
    background: none;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 4px 8px;
    cursor: pointer;
    font-size: 12px;
    color: {{ block.settings.text_color }};
    transition: background-color 0.3s ease;
  }

  .ai-testimonials-helpful-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.border_color }};
  }

  .ai-testimonials-load-more-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-testimonials-load-more-button-{{ ai_gen_id }} {
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-testimonials-load-more-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-testimonials-load-more-button-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-testimonials-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-testimonials-empty-state-{{ ai_gen_id }}.hidden {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-grid-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-testimonials-filters-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-testimonials-filter-group-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-testimonials-filter-select-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<customer-testimonials-{{ ai_gen_id }} class="ai-testimonials-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-header-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="ai-testimonials-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    <div class="ai-testimonials-filters-{{ ai_gen_id }}">
      <div class="ai-testimonials-filter-group-{{ ai_gen_id }}">
        <label class="ai-testimonials-filter-label-{{ ai_gen_id }}" for="rating-filter-{{ ai_gen_id }}">Rating:</label>
        <select
          id="rating-filter-{{ ai_gen_id }}"
          class="ai-testimonials-filter-select-{{ ai_gen_id }}"
          data-filter="rating"
        >
          <option value="all">All ratings</option>
          <option value="5">5 stars</option>
          <option value="4">4 stars</option>
        </select>
      </div>

      <div class="ai-testimonials-filter-group-{{ ai_gen_id }}">
        <label class="ai-testimonials-filter-label-{{ ai_gen_id }}" for="sort-filter-{{ ai_gen_id }}">Sort by:</label>
        <select
          id="sort-filter-{{ ai_gen_id }}"
          class="ai-testimonials-filter-select-{{ ai_gen_id }}"
          data-filter="sort"
        >
          <option value="newest">Newest</option>
          <option value="helpful">Most helpful</option>
          <option value="highest">Highest rating</option>
        </select>
      </div>
    </div>
  </div>

  <div class="ai-testimonials-grid-container-{{ ai_gen_id }}" data-reviews-container>
    {% for i in (1..12) %}
      {% liquid
        assign review_enabled_key = 'review_' | append: i | append: '_enabled'
        assign review_name_key = 'review_' | append: i | append: '_name'
        assign review_rating_key = 'review_' | append: i | append: '_rating'
        assign review_title_key = 'review_' | append: i | append: '_title'
        assign review_text_key = 'review_' | append: i | append: '_text'
        assign review_verified_key = 'review_' | append: i | append: '_verified'
        assign review_helpful_key = 'review_' | append: i | append: '_helpful'
        assign review_date_key = 'review_' | append: i | append: '_date'

        assign review_enabled = block.settings[review_enabled_key]
        assign review_name = block.settings[review_name_key]
        assign review_rating = block.settings[review_rating_key]
        assign review_title = block.settings[review_title_key]
        assign review_text = block.settings[review_text_key]
        assign review_verified = block.settings[review_verified_key]
        assign review_helpful = block.settings[review_helpful_key]
        assign review_date = block.settings[review_date_key]
      %}

      {% if review_enabled and review_name != blank %}
        <div
          class="ai-testimonials-card-{{ ai_gen_id }}"
          data-rating="{{ review_rating }}"
          data-helpful="{{ review_helpful }}"
          data-date="{{ review_date }}"
          data-index="{{ i }}"
        >
          <div class="ai-testimonials-card-header-{{ ai_gen_id }}">
            <div class="ai-testimonials-avatar-{{ ai_gen_id }}">
              {{ review_name | slice: 0 | upcase }}
            </div>
            <div class="ai-testimonials-customer-info-{{ ai_gen_id }}">
              <h3 class="ai-testimonials-customer-name-{{ ai_gen_id }}">{{ review_name }}</h3>
              <div class="ai-testimonials-stars-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  {% if star <= review_rating %}
                    <span class="ai-testimonials-star-{{ ai_gen_id }}">★</span>
                  {% else %}
                    <span class="ai-testimonials-star-{{ ai_gen_id }} empty">★</span>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>

          {% if review_title != blank %}
            <h4 class="ai-testimonials-review-title-{{ ai_gen_id }}">{{ review_title }}</h4>
          {% endif %}

          {% if review_text != blank %}
            <p class="ai-testimonials-review-text-{{ ai_gen_id }}">{{ review_text }}</p>
          {% endif %}

          <div class="ai-testimonials-card-footer-{{ ai_gen_id }}">
            {% if review_verified %}
              <div class="ai-testimonials-verified-badge-{{ ai_gen_id }}">
                <svg
                  class="ai-testimonials-verified-icon-{{ ai_gen_id }}"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                Verified Purchase
              </div>
            {% endif %}

            {% if review_helpful > 0 %}
              <div class="ai-testimonials-helpful-{{ ai_gen_id }}">
                <button class="ai-testimonials-helpful-button-{{ ai_gen_id }}" aria-label="Mark as helpful">👍</button>
                <span>{{ review_helpful }} found helpful</span>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-testimonials-empty-state-{{ ai_gen_id }} hidden">
    <p>No reviews match your filters. Try adjusting your selection.</p>
  </div>

  {% if block.settings.show_load_more %}
    <div class="ai-testimonials-load-more-{{ ai_gen_id }}">
      <button class="ai-testimonials-load-more-button-{{ ai_gen_id }}" data-load-more>
        {{ block.settings.load_more_text }}
      </button>
    </div>
  {% endif %}
</customer-testimonials-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerTestimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.reviewsPerPage = {{ block.settings.reviews_per_page }};
        this.currentPage = 1;
        this.allReviews = [];
        this.filteredReviews = [];
      }

      connectedCallback() {
        this.container = this.querySelector('[data-reviews-container]');
        this.loadMoreBtn = this.querySelector('[data-load-more]');
        this.emptyState = this.querySelector('.ai-testimonials-empty-state-{{ ai_gen_id }}');
        this.ratingFilter = this.querySelector('[data-filter="rating"]');
        this.sortFilter = this.querySelector('[data-filter="sort"]');

        this.allReviews = Array.from(this.container.querySelectorAll('.ai-testimonials-card-{{ ai_gen_id }}'));
        this.filteredReviews = [...this.allReviews];

        this.setupEventListeners();
        this.applyPagination();
      }

      setupEventListeners() {
        if (this.loadMoreBtn) {
          this.loadMoreBtn.addEventListener('click', () => this.loadMore());
        }

        if (this.ratingFilter) {
          this.ratingFilter.addEventListener('change', () => this.applyFilters());
        }

        if (this.sortFilter) {
          this.sortFilter.addEventListener('change', () => this.applySort());
        }

        const helpfulButtons = this.querySelectorAll('.ai-testimonials-helpful-button-{{ ai_gen_id }}');
        helpfulButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const card = button.closest('.ai-testimonials-card-{{ ai_gen_id }}');
            const helpfulCount = card.querySelector('.ai-testimonials-helpful-{{ ai_gen_id }} span');
            if (helpfulCount) {
              const currentCount = parseInt(helpfulCount.textContent);
              helpfulCount.textContent = `${currentCount + 1} found helpful`;
            }
          });
        });
      }

      applyFilters() {
        const ratingValue = this.ratingFilter ? this.ratingFilter.value : 'all';

        this.filteredReviews = this.allReviews.filter(review => {
          const rating = parseInt(review.dataset.rating);

          if (ratingValue !== 'all' && rating !== parseInt(ratingValue)) {
            return false;
          }

          return true;
        });

        this.applySort();
      }

      applySort() {
        const sortValue = this.sortFilter ? this.sortFilter.value : 'newest';

        this.filteredReviews.sort((a, b) => {
          if (sortValue === 'newest') {
            return new Date(b.dataset.date) - new Date(a.dataset.date);
          } else if (sortValue === 'helpful') {
            return parseInt(b.dataset.helpful) - parseInt(a.dataset.helpful);
          } else if (sortValue === 'highest') {
            return parseInt(b.dataset.rating) - parseInt(a.dataset.rating);
          }
          return 0;
        });

        this.currentPage = 1;
        this.renderReviews();
      }

      renderReviews() {
        this.allReviews.forEach(review => review.classList.add('hidden'));

        const visibleCount = this.currentPage * this.reviewsPerPage;
        const reviewsToShow = this.filteredReviews.slice(0, visibleCount);

        reviewsToShow.forEach(review => {
          review.classList.remove('hidden');
          this.container.appendChild(review);
        });

        if (this.emptyState) {
          if (this.filteredReviews.length === 0) {
            this.emptyState.classList.remove('hidden');
          } else {
            this.emptyState.classList.add('hidden');
          }
        }

        if (this.loadMoreBtn) {
          if (visibleCount >= this.filteredReviews.length) {
            this.loadMoreBtn.classList.add('hidden');
          } else {
            this.loadMoreBtn.classList.remove('hidden');
          }
        }
      }

      applyPagination() {
        this.renderReviews();
      }

      loadMore() {
        this.currentPage++;
        this.renderReviews();
      }
    }

    customElements.define('customer-testimonials-{{ ai_gen_id }}', CustomerTestimonials{{ ai_gen_id }});
  })();
</script>

