{{ 'product-bundle.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}


{%- style -%}
    .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}


<section class="bundle-section section-{{ section.id }}-padding color-{{ section.settings.section_color_scheme }}">
  <div class="page-width">
    <div class="bundle-container-inner grid">
      <!-- Left Side: Product List -->
      <div class="bundle-products grid">
        {% assign products = section.settings.collection.products %}
        {% for product in products %}
          {% comment %} {% render 'card-product',
          card_product: product,
          media_aspect_ratio: section.settings.image_ratio,
          image_shape: section.settings.image_shape,
          show_secondary_image: section.settings.show_secondary_image,
          show_vendor: section.settings.show_vendor,
          show_rating: section.settings.show_rating,
          section_id: section.id,
          quick_add: section.settings.quick_add
        %} {% endcomment %}
             <div class="product-card">
            <h3>{{ product.title }}</h3>
            <img src="{{ product.featured_image | image_url }}" width="" height="" alt="{{ product.title }}">
            <p>{{ product.price | money }}</p>
            <button class="add-to-bundle" data-product-id="{{ product.id }}">Add to Bundle</button>
            </div> 
        {% endfor %}
      </div>

      <!-- Right Side: Bundle Box -->
      <div class="bundle-box">
      <h2>Your Bundle</h2>
      <ul class="bundle-list">
          <li class="bundle-item" data-product-id="12345">
              <span class="product-name">Example Product</span>
              <div class="quantity-controls">
              <button class="decrease-quantity" data-index="0">-</button>
              <input type="number" class="product-quantity" value="1" min="1" readonly>
              <button class="increase-quantity" data-index="0">+</button>
              </div>
              <button class="remove-product" data-index="0">Remove</button>
          </li>
          </ul>
          <button class="add-bundle-to-cart" disabled>Add Bundle to Cart</button>
      </div>
    </div>
  </div>
</section>


<script>
    document.addEventListener("DOMContentLoaded", function () {
  const addToBundleButtons = document.querySelectorAll(".add-to-bundle");
  const bundleList = document.querySelector(".bundle-list");
  const addBundleToCartButton = document.querySelector(".add-bundle-to-cart");

  const BUNDLE_STORAGE_KEY = "bundleProducts";

  // Initialize bundle products from localStorage
  let bundleProducts = JSON.parse(localStorage.getItem(BUNDLE_STORAGE_KEY)) || [];

  // Render the bundle list from localStorage
  function renderBundleList() {
    // Clear existing list
    const bundleItems = bundleList.querySelectorAll(".bundle-item");
    bundleItems.forEach(item => item.remove());

    bundleProducts.forEach((product, index) => {
      const bundleItem = document.createElement("li");
      bundleItem.classList.add("bundle-item");
      bundleItem.setAttribute("data-product-id", product.id);

      bundleItem.innerHTML = `
        <span class="product-name">${product.name}</span>
        <div class="quantity-controls">
          <button class="decrease-quantity" data-index="${index}">-</button>
          <input type="number" class="product-quantity" value="${product.quantity}" min="1" readonly>
          <button class="increase-quantity" data-index="${index}">+</button>
        </div>
        <button class="remove-product" data-index="${index}">Remove</button>
      `;

      bundleList.appendChild(bundleItem);
    });

    // Enable or disable the "Add Bundle to Cart" button
    addBundleToCartButton.disabled = bundleProducts.length === 0;

    // Attach event listeners for quantity controls and remove buttons
    attachEventListeners();
  }

  // Update localStorage and re-render
  function updateBundleStorage() {
    localStorage.setItem(BUNDLE_STORAGE_KEY, JSON.stringify(bundleProducts));
    renderBundleList();
  }

  // Attach event listeners for quantity controls and remove buttons
  function attachEventListeners() {
    const decreaseButtons = document.querySelectorAll(".decrease-quantity");
    const increaseButtons = document.querySelectorAll(".increase-quantity");
    const removeButtons = document.querySelectorAll(".remove-product");

    decreaseButtons.forEach(button => {
      button.addEventListener("click", function () {
        const index = this.dataset.index;
        if (bundleProducts[index].quantity > 1) {
          bundleProducts[index].quantity -= 1;
          updateBundleStorage();
        }
      });
    });

    increaseButtons.forEach(button => {
      button.addEventListener("click", function () {
        const index = this.dataset.index;
        bundleProducts[index].quantity += 1;
        updateBundleStorage();
      });
    });

    removeButtons.forEach(button => {
      button.addEventListener("click", function () {
        const index = this.dataset.index;
        bundleProducts.splice(index, 1); // Remove the product from the array
        updateBundleStorage();
      });
    });
  }

  // Add Product to Bundle
  addToBundleButtons.forEach(button => {
    button.addEventListener("click", function () {
      const productId = this.dataset.productId;

      // Check if the product is already in the bundle
      const existingProduct = bundleProducts.find(product => product.id === productId);
      if (existingProduct) {
        alert("Product already in bundle!");
        return;
      }

      // Add product to the bundleProducts array
      const productName = this.closest(".product-card").querySelector("h3").textContent;
      bundleProducts.push({ id: productId, name: productName, quantity: 1 });

      updateBundleStorage();
    });
  });

  renderBundleList();
});

</script>


{% schema %}
    {
      "name": "Test product bundle",
      "settings": [
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:sections.all.colors.label",
          "default": "scheme-1"
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "Chose collection"
        },





        {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.featured-collection.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.featured-collection.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.featured-collection.settings.image_ratio.options__3.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.featured-collection.settings.image_ratio.label"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.featured-collection.settings.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.featured-collection.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "t:sections.featured-collection.settings.show_rating.label",
      "info": "t:sections.featured-collection.settings.show_rating.info"
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "none",
      "label": "t:sections.main-collection-product-grid.settings.quick_add.label",
      "info": "t:sections.main-collection-product-grid.settings.quick_add.info",
      "options": [
        {
          "value": "none",
          "label": "t:sections.main-collection-product-grid.settings.quick_add.options.option_1"
        },
        {
          "value": "standard",
          "label": "t:sections.main-collection-product-grid.settings.quick_add.options.option_2"
        },
        {
          "value": "bulk",
          "label": "t:sections.main-collection-product-grid.settings.quick_add.options.option_3"
        }
      ]
    },


        {
            "type": "header",
            "content": "t:sections.all.padding.section_padding_heading"
        },
        {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 120,
            "step": 5,
            "unit": "px",
            "label": "t:sections.all.padding.padding_top",
            "default": 120
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "min": 0,
            "max": 120,
            "step": 5,
            "unit": "px",
            "label": "t:sections.all.padding.padding_bottom",
            "default": 120
        }
      ],
      "presets": [
        {
            "name": "Test product bundle"
        }
      ]
    }
    {% endschema %}
    