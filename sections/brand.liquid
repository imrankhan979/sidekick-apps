{% doc %}
  @prompt
    Create a brand identity section for a Shopify storefront that includes: a powerful Brand Story Headline (max 8 words), a Brand Description with 2-3 sentences about the company's mission, values, or unique positioning, Key Brand Elements as 3-4 styled bullet points highlighting core attributes like "Sustainable", "Innovative", "Customer-Focused", a Logo/Brand Image area with recommended placement for a company logo or brand photography, and an optional CTA button (e.g., "Learn Our Story"). The section should feel authentic, compelling, and visually polished — with a clean layout, strong typography, and a tone that reflects brand identity. Make all text and image fields customizable in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-identity-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-brand-identity-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ai-brand-identity-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-brand-identity-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.2;
    color: {{ block.settings.headline_color }};
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ai-brand-identity-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-brand-identity-description-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-brand-identity-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-brand-identity-elements-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-brand-identity-element-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.element_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-brand-identity-element-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
  }

  .ai-brand-identity-element-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    fill: {{ block.settings.icon_color }};
  }

  .ai-brand-identity-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: 600;
    font-size: {{ block.settings.button_size }}px;
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_border }};
    align-self: flex-start;
  }

  .ai-brand-identity-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_border }};
    transform: translateY(-2px);
  }

  .ai-brand-identity-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-brand-identity-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-brand-identity-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_radius }}px;
    position: relative;
  }

  .ai-brand-identity-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-brand-identity-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-brand-identity-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-brand-identity-headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.8);
    }

    .ai-brand-identity-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }

    .ai-brand-identity-image-wrapper-{{ ai_gen_id }} {
      min-height: 300px;
    }

    {% if block.settings.layout == 'image_first' %}
      .ai-brand-identity-content-{{ ai_gen_id }} {
        order: 2;
      }
      .ai-brand-identity-image-wrapper-{{ ai_gen_id }} {
        order: 1;
      }
    {% endif %}
  }

  {% if block.settings.layout == 'image_first' %}
    @media screen and (min-width: 990px) {
      .ai-brand-identity-content-{{ ai_gen_id }} {
        order: 2;
      }
      .ai-brand-identity-image-wrapper-{{ ai_gen_id }} {
        order: 1;
      }
    }
  {% endif %}

  {% if block.settings.text_alignment == 'center' %}
    .ai-brand-identity-content-{{ ai_gen_id }} {
      align-items: center;
      text-align: center;
    }
  {% elsif block.settings.text_alignment == 'right' %}
    .ai-brand-identity-content-{{ ai_gen_id }} {
      align-items: flex-end;
      text-align: right;
    }
  {% endif %}
{% endstyle %}

<div class="ai-brand-identity-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-identity-container-{{ ai_gen_id }}">
    <div class="ai-brand-identity-content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-brand-identity-headline-{{ ai_gen_id }}">
          {{ block.settings.headline }}
        </h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-brand-identity-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.show_elements %}
        <ul class="ai-brand-identity-elements-{{ ai_gen_id }}">
          {% if block.settings.element_1 != blank %}
            <li class="ai-brand-identity-element-{{ ai_gen_id }}">
              <span class="ai-brand-identity-element-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
              </span>
              <span>{{ block.settings.element_1 }}</span>
            </li>
          {% endif %}

          {% if block.settings.element_2 != blank %}
            <li class="ai-brand-identity-element-{{ ai_gen_id }}">
              <span class="ai-brand-identity-element-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
              </span>
              <span>{{ block.settings.element_2 }}</span>
            </li>
          {% endif %}

          {% if block.settings.element_3 != blank %}
            <li class="ai-brand-identity-element-{{ ai_gen_id }}">
              <span class="ai-brand-identity-element-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
              </span>
              <span>{{ block.settings.element_3 }}</span>
            </li>
          {% endif %}

          {% if block.settings.element_4 != blank %}
            <li class="ai-brand-identity-element-{{ ai_gen_id }}">
              <span class="ai-brand-identity-element-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
              </span>
              <span>{{ block.settings.element_4 }}</span>
            </li>
          {% endif %}
        </ul>
      {% endif %}

      {% if block.settings.show_cta and block.settings.cta_text != blank %}
        <a href="{{ block.settings.cta_link }}" class="ai-brand-identity-cta-{{ ai_gen_id }}">
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-brand-identity-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.brand_image %}
        <img
          src="{{ block.settings.brand_image | image_url: width: 1000 }}"
          alt="{{ block.settings.brand_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.brand_image.width }}"
          height="{{ block.settings.brand_image.height }}"
          class="ai-brand-identity-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-brand-identity-image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-brand-identity-empty-state-{{ ai_gen_id }}">Add your brand logo or image</div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brand identity",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        {
          "value": "content_first",
          "label": "Right"
        },
        {
          "value": "image_first",
          "label": "Left"
        }
      ],
      "default": "image_first"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Brand headline"
    },
    {
      "type": "inline_richtext",
      "id": "headline",
      "label": "Headline",
      "default": "Crafting Excellence Since Day One"
    },
    {
      "type": "font_picker",
      "id": "headline_font",
      "label": "Headline font",
      "default": "oswald_n4"
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Headline size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Brand description"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We believe in creating products that stand the test of time. Our commitment to quality, sustainability, and innovation drives everything we do. From sourcing the finest materials to delivering exceptional customer experiences, we're dedicated to making a positive impact.</p>"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "archivo_n4"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Brand elements"
    },
    {
      "type": "checkbox",
      "id": "show_elements",
      "label": "Show brand elements",
      "default": true
    },
    {
      "type": "text",
      "id": "element_1",
      "label": "Element 1",
      "default": "Sustainable & Eco-Friendly"
    },
    {
      "type": "text",
      "id": "element_2",
      "label": "Element 2",
      "default": "Innovation-Driven Design"
    },
    {
      "type": "text",
      "id": "element_3",
      "label": "Element 3",
      "default": "Customer-Focused Approach"
    },
    {
      "type": "text",
      "id": "element_4",
      "label": "Element 4",
      "default": "Quality Craftsmanship"
    },
    {
      "type": "range",
      "id": "element_size",
      "label": "Element text size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Brand image"
    },
    {
      "type": "image_picker",
      "id": "brand_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Learn Our Story"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button text size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border",
      "label": "Button border",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_text",
      "label": "Hover text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_border",
      "label": "Hover border",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Brand identity"
    }
  ]
}
{% endschema %}
