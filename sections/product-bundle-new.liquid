
{{ 'product-bundle.css' | asset_url | stylesheet_tag }}


<script>
  window.currencySymbol = "{{ cart.currency.symbol }}";
</script>
<script src="{{ 'bundle.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}

@media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}
{%- endstyle -%}

<div class="bundle-section section-{{ section.id }}-padding color-{{ section.settings.section_color_scheme }}">
  <div class="page-width">
    <div class="bundle-container-inner grid">
        <!-- Left Section: Product List -->
        <div id="product-list" class="bundle-products grid">
        
          {% for product in section.settings.collection.products %}
            <div class="product" data-title="{{ product.title }}">
              <a href="{{ product.url }}" class="product-image">
                <img src="{{ product.featured_image | img_url: 'large' }}" width="" height="" alt="{{ product.title }}">
              </a>
                <h5 class="product-title"><a href="{{ product.url }}">{{ product.title }}</a></h5>
                <p class="product-price" id="product-price-{{ product.id }}">{{ product.variants.first.price | money }}</p>

                {% assign showVariant = false %}
                {% for option in product.options_with_values %}
                  {% if option.name != "Title"  %}
                    {% assign showVariant = true %}
                  {% endif %}
                {% endfor %}

                {% if showVariant %}
                  <div class="variant-picker">
                    {% for option in product.options_with_values %}
                      <div class="variant-group{% if option.name == 'Color' %} color-swatch{% endif %}">
                        <p class="variant-group-name">{{ option.name }}</p>
                        {% for value in option.values %}
                        <input id="{{product.id}}-{{value}}" type="radio" name="option-{{product.id}}-{{ option.name | handleize }}" value="{{ value }}" data-option-index="{{ forloop.parentloop.index0 }}" data-value="{{ value }}" data-product-id="{{ product.id }}" {% if forloop.first %}checked{% endif %}>
                          {%- liquid
                              assign swatch_value = null
                              if value.swatch.image
                                assign image_url = value.swatch.image | image_url: width: 50
                                assign swatch_value = 'url(' | append: image_url | append: ')'
                              elsif value.swatch.color
                                assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                              endif
                            -%}
                          <label for="{{product.id}}-{{value}}"  style="--swatch--background: {{ swatch_value }}" >
                            {{ value }}
                          </label>
                        {% endfor %}
                      </div>
                    {% endfor %}
                  </div>
                  
                {% endif %}
                <input class="product-variant-id" type="hidden" name="id" id="selected-variant-{{ product.id }}" value="{{ product.variants.first.id }}">
                <button type="submit" class="add-to-bundle" id="add-to-cart-{{ product.id }}" {% unless product.variants.first.available %}disabled{% endunless %}>{% if product.variants.first.available %}Add to cart {% else %}Sold out{% endif %}</button>
            </div>
            
            <script>
                  document.addEventListener("DOMContentLoaded", function() {
                    document.querySelectorAll(".variant-picker input").forEach(input => {
                      input.addEventListener("change", function() {
                        let productId = this.dataset.productId;
                        let selectedOptions = [];
                        
                        document.querySelectorAll(`[data-product-id='${productId}']`).forEach(option => {
                          if (option.checked) {
                            selectedOptions[option.dataset.optionIndex] = option.dataset.value;
                          }
                        });
                        // console.log({{ product.variants | json }})
                        let selectedVariant = {{ product.variants | json }}.find(variant => {  return JSON.stringify(variant.options) === JSON.stringify(selectedOptions); });
                        
                        if (selectedVariant) {
                          document.getElementById(`selected-variant-${productId}`).value = selectedVariant.id;

                          let currencySymbol = "{{ cart.currency.symbol }}"; 
                          document.getElementById(`product-price-${productId}`).innerText = currencySymbol + (selectedVariant.price / 100).toFixed(2);
                          
                          let addToCartButton = document.getElementById(`add-to-cart-${productId}`);
                          if (addToCartButton.disabled = !selectedVariant.available) {
                            addToCartButton.innerHTML = "Sold out"
                          }else {
                            addToCartButton.innerHTML = "Add to cart"
                          }
                          ;
                        }
                      });
                    });
                  });
            </script>

          {% endfor %}
        </div>
        <!-- Right Section: Bundle List -->
        <div id="bundle-list">
          <div class="bundle-list-inner">
            <div class="bundle-list-header">
              <h5>{{ section.settings.bundle_cart_heading }}</h5>
              <p>{{ section.settings.bundle_cart_subheading }}</p>
              <div id="item-range" class="item-range"></div>
            </div>
            <div class="bundle-list-body no-scrollbar">
              <ul id="bundle-items">
                <!-- JavaScript will dynamically populate this list -->
              </ul>
            </div>
            <div class="bundle-list-footer">
              <div class="bundle-list-footer-inner">
                <div class="bundle-total-price flex space-between align-items-center"><span>SUBTOTAL</span><span id="bundle-total">$00.00</span></div>
              <button class="add-to-cart">ADD TO CART</button>
              </div>
            </div>
          </div>
        </div>
    </div>
  </div>
</div>





{% schema %}
    {
      "name": "Product bundle New",
      "settings": [
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:sections.all.colors.label",
          "default": "scheme-1"
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "Chose collection"
        },
        {
          "type": "header",
          "content": "t:sections.featured-collection.settings.header.content"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "options": [
            {
              "value": "adapt",
              "label": "t:sections.featured-collection.settings.image_ratio.options__1.label"
            },
            {
              "value": "portrait",
              "label": "t:sections.featured-collection.settings.image_ratio.options__2.label"
            },
            {
              "value": "square",
              "label": "t:sections.featured-collection.settings.image_ratio.options__3.label"
            }
          ],
          "default": "portrait",
          "label": "t:sections.featured-collection.settings.image_ratio.label"
        },
        {
          "type": "checkbox",
          "id": "show_secondary_image",
          "default": false,
          "label": "t:sections.featured-collection.settings.show_secondary_image.label"
        },
        {
          "type": "checkbox",
          "id": "show_vendor",
          "default": true,
          "label": "t:sections.featured-collection.settings.show_vendor.label"
        },
        {
          "type": "checkbox",
          "id": "show_rating",
          "default": false,
          "label": "t:sections.featured-collection.settings.show_rating.label",
          "info": "t:sections.featured-collection.settings.show_rating.info"
        },
        {
          "type": "select",
          "id": "picker_type",
          "options": [
            {
              "value": "dropdown",
              "label": "t:sections.featured-product.blocks.variant_picker.settings.picker_type.options__1.label"
            },
            {
              "value": "button",
              "label": "t:sections.featured-product.blocks.variant_picker.settings.picker_type.options__2.label"
            }
          ],
          "default": "button",
          "label": "t:sections.featured-product.blocks.variant_picker.settings.picker_type.label"
        },
        {
          "id": "swatch_shape",
          "label": "t:sections.featured-product.blocks.variant_picker.settings.swatch_shape.label",
          "type": "select",
          "info": "t:sections.featured-product.blocks.variant_picker.settings.swatch_shape.info",
          "options": [
            {
              "value": "circle",
              "label": "t:sections.featured-product.blocks.variant_picker.settings.swatch_shape.options__1.label"
            },
            {
              "value": "square",
              "label": "t:sections.featured-product.blocks.variant_picker.settings.swatch_shape.options__2.label"
            },
            {
              "value": "none",
              "label": "t:sections.main-product.blocks.variant_picker.settings.swatch_shape.options__3.label"
            }
          ],
          "default": "circle"
        },
        {
            "type": "header",
            "content": "Bundle cart"
        },
        {
          "type": "inline_richtext",
          "id": "bundle_cart_heading",
          "label": "Bundle cart heading",
          "default": "BUNDLE CART"
        },
        {
          "type": "inline_richtext",
          "id": "bundle_cart_subheading",
          "label": "Bundle cart subheading",
          "default": "Add at least 3 items to get 30% OFF"
        },
        {
            "type": "header",
            "content": "t:sections.all.padding.section_padding_heading"
        },
        {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 120,
            "step": 5,
            "unit": "px",
            "label": "t:sections.all.padding.padding_top",
            "default": 120
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "min": 0,
            "max": 120,
            "step": 5,
            "unit": "px",
            "label": "t:sections.all.padding.padding_bottom",
            "default": 120
        }
      ],
      "presets": [
        {
            "name": "Product bundle New"
        }
      ]
    }
    {% endschema %}
    