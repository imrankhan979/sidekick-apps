{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
    .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer rounded-top-corner color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="footer-inner">
    <div class="footer-top-content page-width">

        {%- assign newsletter = false -%} 
        {%- assign logo = false -%}
        {%- for block in section.blocks -%} 
          {%- if block.type == 'newsletter' -%}
            {%- assign newsletter = true -%}
          {%- elsif block.type == 'logo' -%}
            {%- assign logo = true -%}
          {%- elsif block.type == 'nav_links' -%}
            {%- assign nav_links = true -%}
          {%- endif -%}
        {%- endfor -%}
        <div class="footer-top-content-inner{% if newsletter or logo %} has-left-blocks{% else %} no-left-blocks{% endif %}">

          <div class="footer-top-left">
            {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%} 
                {% render block %}
              {%- when 'newsletter' -%}
                <div class="footer-newsletter" {{ block.shopify_attributes }}>
                    <div class="newsletter">
                      {%- if block.settings.newsletter_heading != blank -%}
                        <h6 class="newsletter-heading uppercase">{{ block.settings.newsletter_heading }}</h6>
                      {%- endif -%}
                      {%- form 'customer', id: 'ContactFooter', class: 'footer-newsletter newsletter-form' -%}
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="newsletter-form-field-wrapper flex">
                          <div class="field-inner">
                            <input
                              id="NewsletterForm--{{ section.id }}"
                              type="email"
                              name="contact[email]"
                              class="newsletter-form-input"
                              value="{{ form.email }}"
                              aria-required="true"
                              autocorrect="off"
                              autocapitalize="off"
                              autocomplete="email"
                              {% if form.errors %}
                                autofocus
                                aria-invalid="true"
                                aria-describedby="ContactFooter-error"
                              {% elsif form.posted_successfully? %}
                                aria-describedby="ContactFooter-success"
                              {% endif %}
                              placeholder="{{ 'newsletter.label' | t }}"
                              required
                            >
                            <button
                              type="submit"
                              class="newsletter-form-button"
                              name="commit"
                              id="Subscribe"
                              aria-label="{{ 'newsletter.button_label' | t }}"
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-arrow.svg' | inline_asset_content -}}
                              </span>
                            </button>
                          </div>
                          {%- if form.errors -%}
                            <small class="newsletter-form__message form__message" id="ContactFooter-error">
                              <span class="svg-wrapper">
                                {{- 'icon-error.svg' | inline_asset_content -}}
                              </span>
                              {{- form.errors.translated_fields.email | capitalize }}
                              {{ form.errors.messages.email -}}
                            </small>
                          {%- endif -%}
                        </div>
                        {%- if form.posted_successfully? -%}
                          <h3
                            class="newsletter-form__message newsletter-form__message--success form__message"
                            id="ContactFooter-success"
                            tabindex="-1"
                            autofocus
                          >
                            <span class="svg-wrapper">
                              {{- 'icon-success.svg' | inline_asset_content -}}
                            </span>
                            {{- 'newsletter.success' | t }}
                          </h3>
                        {%- endif -%}
                      {%- endform -%}
                    </div>
                </div>
              {%- when 'logo' -%}
                <div class="footer-logo"
                  {{ block.shopify_attributes }}>
                  <a href="{{ routes.root_url }}">
                    <div class="footer-heading-logo-wrapper flex" style="max-width: {{block.settings.logo_width}}%;">
                    {% if block.settings.logo != blank %}
                      {{ block.settings.logo | image_url: width: 1200 | image_tag:
                          class: 'footer-logo-img',
                          preload: true
                      }}
                    {% endif %}
                  </div>
                  </a>
                </div>
            {%- endcase -%}


          {%- endfor -%}
          </div>
          <div class="footer-top-right{% if nav_links %} space-between{% else %} justify-content-end {% endif %}">
            {%- if nav_links -%}
            <div class="footer-navigation-link-wrapper">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                    {%- when 'nav_links' -%}
                      <div class="footer-navigation-links"
                        {{ block.shopify_attributes }}
                        >
                        {% assign menu_title = block.settings.menu.title %}
                        {% assign display_title = block.settings.title | default: menu_title %}
                        <responsive-dropdown-menu>
                        <h3 class="footer-navigation-links-title uppercase menu-btn">{{ display_title }}</h3>
                        <ul class="footer-navigation-links-list menu-list">
                          {% for link in block.settings.menu.links %}
                            <li>
                              <a href="{{ link.url }}" title="{{ link.title }}">{{ link.title }}</a>
                            </li>
                          {% endfor %}
                        </ul>
                        </responsive-dropdown-menu>
                      </div>
                  {%- endcase -%}
              {%- endfor -%}
            </div>
            {%- endif -%}
            {%- if section.settings.show_copyright == true or section.settings.show_policy == true -%}
            
            <div class="footer-copyright">
              <div class="footer-copyright-inner">
                {%- if section.settings.show_copyright -%}
                  <div class="copyright-content uppercase flex wrap">
                  {{ shop.name | link_to: routes.root_url }} &copy; {{ 'now' | date: '%Y' }}. {% if section.settings.additional_copyright_text != blank %} {{ section.settings.additional_copyright_text }}{% endif %}
                  </div>  
                {%- endif -%}

                {%- if section.settings.copyright_bottom_text -%}
                  <div class="copyright-bottom-text">
                    <p>{{ section.settings.copyright_bottom_text }}</p> 
                  </div>
                {%- endif -%} 

                {%- if section.settings.show_policy -%}
                  <ul class="policies">
                    {%- for policy in shop.policies -%}
                      {%- if policy != blank -%}
                        <li>
                          <div class="policy-page"
                            ><a href="{{ policy.url }}">{{ policy.title | escape }}</a></div
                          >
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
                </div>
              </div>
        {%- endif -%}
        </div>
    </div>
    <div class="footer-bottom-content {% if section.settings.payment_enable != true %}md-none{% endif %}">
        <div class="footer-bottom-content-inner flex space-between wrap">
          {%- if section.settings.payment_enable -%}
            <div class="footer-payment">
              <ul class="list list-payment flex align-items-center" role="list">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="list-payment-item">
                    {{ type | payment_type_svg_tag: class: 'payment-icon' }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <button class="back-to-top uppercase flex align-items-center" id="back-to-top">
            BACK TO TOP <span class="flex center"> {{- 'icon-caret.svg' | inline_asset_content -}} </span>
          </button>
        </div>
    </div>
  </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "name": "t:sections.footer.blocks.link_list.name",
      "type": "nav_links",
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label",
          "info": "t:sections.footer.blocks.link_list.settings.heading.info"
            }
          ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "newsletter_heading",
          "default": "GET 15% OFF ON YOUR FIRST ORDER",
          "label": "Newsletter heading"
        }
      ]
    },
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "range",
          "id": "logo_width",
          "label": "Logo width",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 100
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__10.content"
    },
    {
      "type": "checkbox",
      "id": "show_copyright",
      "default": true,
      "label": "t:sections.footer.settings.show_copyright.label"
    },
    {
      "type": "inline_richtext",
      "id": "additional_copyright_text",
      "label": "t:sections.footer.settings.additional_copyright_text.label",
      "default": "t:sections.footer.settings.additional_copyright_text.default"
    },
    {
      "type": "richtext",
      "id": "copyright_bottom_text",
      "label": "t:sections.footer.settings.copyright_bottom_text.label",
      "default": "t:sections.footer.settings.copyright_bottom_text.default"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__8.content",
      "info": "t:sections.footer.settings.header__8.info"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": false,
      "label": "t:sections.footer.settings.show_policy.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__7.content"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
        {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.footer.name",
      "blocks": [
        {
          "type": "newsletter"
        },
        {
          "type": "logo"
        },
        {
          "type": "nav_links"
        },
        {
          "type": "nav_links"
        },
        {
          "type": "nav_links"
        },
        {
          "type": "nav_links"
        }
      ]
    }
  ]
}
{% endschema %}
