{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer rounded-top-corner color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="footer-inner">
    <div class="footer-top-content page-width">
        <div class="footer-top-content-inner">
          <div class="footer-top-left">
            {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'newsletter' -%}
                <div class="footer-newsletter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                  {% endif %} {{ block.shopify_attributes }}>
                    <div class="newsletter">
                      {%- if block.settings.newsletter_heading != blank -%}
                        <h6 class="newsletter-heading">{{ block.settings.newsletter_heading }}</h6>
                      {%- endif -%}
                      {%- form 'customer', id: 'ContactFooter', class: 'footer-newsletter newsletter-form' -%}
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="newsletter-form-field-wrapper flex">
                          <div class="field-inner">
                            <input
                              id="NewsletterForm--{{ section.id }}"
                              type="email"
                              name="contact[email]"
                              class="newsletter-form-input"
                              value="{{ form.email }}"
                              aria-required="true"
                              autocorrect="off"
                              autocapitalize="off"
                              autocomplete="email"
                              {% if form.errors %}
                                autofocus
                                aria-invalid="true"
                                aria-describedby="ContactFooter-error"
                              {% elsif form.posted_successfully? %}
                                aria-describedby="ContactFooter-success"
                              {% endif %}
                              placeholder="{{ 'newsletter.label' | t }}"
                              required
                            >
                            <button
                              type="submit"
                              class="newsletter-form-button"
                              name="commit"
                              id="Subscribe"
                              aria-label="{{ 'newsletter.button_label' | t }}"
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-arrow.svg' | inline_asset_content -}}
                              </span>
                            </button>
                          </div>
                          {%- if form.errors -%}
                            <small class="newsletter-form__message form__message" id="ContactFooter-error">
                              <span class="svg-wrapper">
                                {{- 'icon-error.svg' | inline_asset_content -}}
                              </span>
                              {{- form.errors.translated_fields.email | capitalize }}
                              {{ form.errors.messages.email -}}
                            </small>
                          {%- endif -%}
                        </div>
                        {%- if form.posted_successfully? -%}
                          <h3
                            class="newsletter-form__message newsletter-form__message--success form__message"
                            id="ContactFooter-success"
                            tabindex="-1"
                            autofocus
                          >
                            <span class="svg-wrapper">
                              {{- 'icon-success.svg' | inline_asset_content -}}
                            </span>
                            {{- 'newsletter.success' | t }}
                          </h3>
                        {%- endif -%}
                      {%- endform -%}
                    </div>
                </div>
              {%- when 'logo' -%}
                <div class="footer-logo {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                  {% endif %} {{ block.shopify_attributes }}>
                  <a href="{{ routes.root_url }}">
                    <div class="footer-heading-logo-wrapper flex" style="max-width: {{block.settings.logo_width}}%;">
                    {% if block.settings.logo != blank %}
                      {{ block.settings.logo | image_url: width: 1200 | image_tag:
                          class: 'footer-logo-img',
                          preload: true
                      }}
                    {% endif %}
                  </div>
                  </a>
                </div>
            {%- endcase -%}


          {%- endfor -%}
          </div>
          <div class="footer-top-right">
            <div class="footer-navigation-link-wrapper">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                    {%- when 'quick_links' -%}
                      <div class="footer-navigation-links {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                        {{ block.shopify_attributes }}
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                          style="--animation-order: {{ forloop.index }};"
                        {% endif %}>
                        {% assign menu_title = block.settings.menu.title %}
                        {% assign display_title = block.settings.title | default: menu_title %}
                        <responsive-dropdown-menu>
                        <h3 class="footer-navigation-links-title menu-btn">{{ display_title }}</h3>
                        <ul class="footer-navigation-links-list menu-list">
                          {% for link in block.settings.menu.links %}
                            <li>
                              <a href="{{ link.url }}" title="{{ link.title }}">{{ link.title }}</a>
                            </li>
                          {% endfor %}
                        </ul>
                        </responsive-dropdown-menu>
                      </div>
                  {%- endcase -%}
              {%- endfor -%}
            </div>
            {%- if section.settings.show_copyright == true or section.settings.show_policy == true -%}
            
            <div class="footer-copyright {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                  {% endif %}>
              <div class="footer-copyright-inner">
                {%- if section.settings.show_copyright -%}
                  <div class="copyright-content"
                    ><span>{{ shop.name | link_to: routes.root_url -}}</span> &copy; {{ 'now' | date: '%Y' }}. {%- if section.settings.additional_copyright_text != blank -%}<span class="additional-copyright-text"> {{ section.settings.additional_copyright_text }}</span>{%- endif -%}
                  </div>  
                {%- endif -%}

                {%- if section.settings.show_policy -%}
                  <ul class="policies">
                    {%- for policy in shop.policies -%}
                      {%- if policy != blank -%}
                        <li>
                          <div class="copyright__content"
                            ><a href="{{ policy.url }}">{{ policy.title | escape }}</a></div
                          >
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
                </div>
              </div>
          </div>
        {%- endif -%}
        </div>
    </div>
  </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "name": "t:sections.footer.blocks.link_list.name",
      "type": "quick_links",
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label",
          "info": "t:sections.footer.blocks.link_list.settings.heading.info"
            }
          ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "newsletter_heading",
          "default": "GET 15% OFF ON YOUR FIRST ORDER",
          "label": "Newsletter heading"
        }
      ]
    },
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "range",
          "id": "logo_width",
          "label": "Logo width",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 100
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__10.content"
    },
    {
      "type": "checkbox",
      "id": "show_copyright",
      "default": true,
      "label": "t:sections.footer.settings.show_copyright.label"
    },
    {
      "type": "inline_richtext",
      "id": "additional_copyright_text",
      "label": "t:sections.footer.settings.additional_copyright_text.label",
      "default": "t:sections.footer.settings.additional_copyright_text.default"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__8.content",
      "info": "t:sections.footer.settings.header__8.info"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "t:sections.footer.settings.show_policy.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__7.content"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
