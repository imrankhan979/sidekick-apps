{{ 'blog-details.css' | asset_url | stylesheet_tag }}
{{ 'breadcrumb.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .main-section-{{ section.id }}-padding {
    padding-top: {{ section.settings.main_padding_top | times: 0.65 | round: 0 }}px;
    padding-bottom: {{ section.settings.main_padding_bottom | times: 0.65 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .main-section-{{ section.id }}-padding {
      padding-top: {{ section.settings.main_padding_top }}px;
      padding-bottom: {{ section.settings.main_padding_bottom }}px;
    }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.65 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="breadcrumb-main-area blog-inner-area color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="breadcrumb-content-area blog-style section-{{ section.id }}-padding">
      {% if section.settings.show_breadcrumb %}
        <div class=" breadcrumb-link">
          <ul>
            <li><a href="{{ routes.root_url }}">{{ 'sections.breadcrumb_banner.home' | t }}</a></li>
            <li>{{ blog.title }}</li>
          </ul>
        </div>
      {% endif %}
      <div class=" breadcrumb-heading">
        <h1 class="breadcrumb-title">{{ article.title }}</h1>
      </div>
      <div class=" blog_category">
        {% if article.tags.size > 0 and section.settings.show_tag %}
          {% for tag in article.tags %}
            <a class="category_text" href="{{ blog.url }}/tagged/{{ tag | handleize }}">
              <span class="blog_anim">
                <span class="anim_text"> {{ tag }}</span>
              </span>
            </a>
          {% endfor %}
        {% endif %}
        {% if article.published_at and section.settings.show_date %}
          <span class="category_text">
            <span class="blog_anim">
              <span class="anim_text"> {{ article.published_at | date: '%b %d, %Y' | upcase }}</span>
            </span>
          </span>
        {% endif %}
      </div>
    </div>
  </div>
</section>
<section class="blog-details-section main-section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="blog_details_main">
      {% if article.image != blank %}
        <div class=" blog_details_lg_images">
          <img
            class="w-full"
            srcset="
              {%- if article.image.src.width >= 165 -%}{{ article.image.src | image_url: width: 165 }} 165w,{%- endif -%}
              {%- if article.image.src.width >= 360 -%}{{ article.image.src | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if article.image.src.width >= 533 -%}{{ article.image.src | image_url: width: 533 }} 533w,{%- endif -%}
              {%- if article.image.src.width >= 720 -%}{{ article.image.src | image_url: width: 720 }} 720w,{%- endif -%}
              {%- if article.image.src.width >= 1000 -%}{{ article.image.src | image_url: width: 1000 }} 1000w,{%- endif -%}
              {%- if article.image.src.width >= 1500 -%}{{ article.image.src | image_url: width: 1500 }} 1500w,{%- endif -%}
              {{ article.image.src | image_url }} {{ article.image.src.width }}w
            "
            src="{{ article.image.src | image_url: width: article.image.width }}"
            sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
            alt="{{ article.image.src.alt | escape }}"
            loading="lazy"
            width="{{ article.image.width }}"
            height="{{ article.image.height }}"
          >
        </div>
      {% endif %}
      <div class="blog_details_Wrapper">
        <div class=" blog_details_content">
          {{ article.content }}
        </div>
        {% if section.settings.show_tag or section.settings.show_social_share %}
        <div class=" blog_details_infos_box">
            {% if article.tags.size > 0 and section.settings.show_tag %}
              <div class="blog_details_tag">
                <ul>
                  <li><span>{{ 'sections.main_article.tag' | t }}</span></li>
                  {% for tag in article.tags %}
                    <li>
                      <a href="{{ blog.url }}/tagged/{{ tag | handleize }}">{{ tag }}</a>
                      {%- unless forloop.last %}, {% endunless %}
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
      
          {% if section.settings.show_social_share %}
            <div class="blog_details_socials">
              <ul>
                <li>
                  <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}"
                      target="_blank"
                      rel="noopener"
                      class="facebook-share-button share-btn">
                      {{ 'icon-facebook.svg' | inline_asset_content }}
                    </a>
                </li>
                <li>
                   <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}&media={{ article.image | img_url: 'master' }}&description={{ article.title }}"
                      target="_blank"
                      rel="noopener"
                      class="pinterest-share-button share-btn">
                      {{ 'icon-pinterest.svg' | inline_asset_content }}
                    </a>
                </li>
                <li>
                   <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title }}"
                    target="_blank"
                    rel="noopener"
                    class="share-btn">
                    {{ 'icon-twitter.svg' | inline_asset_content }}
                  </a>
                </li>
                <li>
                  <button class="share-btn" onclick="copyArticleLink()">
                  {{ 'icon-link.svg' | inline_asset_content }}
                </button>
                <script>
                  function copyArticleLink() {
                    const url = "{{ shop.url }}{{ article.url }}";
                    navigator.clipboard.writeText(url).then(() => {
                      alert('{{ 'button.share_button.product_link' | t }}');
                    }).catch(err => {
                      console.error('{{ 'button.share_button.product_link_error' | t }} ', err);
                    });
                  }
                </script>
                </li>
              </ul>
            </div>
          {% endif %}
        </div>
            {% endif %}

        {% if section.settings.show_author_information %}
          <div class="blog_details_author">
            {% if section.settings.author_image != blank %}
              <div class="blog_thumb_images">
                <img
                  src="{{ section.settings.author_image | image_url: width: 533 }}"
                  loading="lazy"
                  width="{{ section.settings.author_image.width }}"
                  height="{{ section.settings.author_image.height }}"
                >
              </div>
            {% endif %}
            <div class="blog_author_text">
              <h6 class="author_name">{{ article.author }}</h6>
              {% if section.settings.author_designation != blank %}
                <span class="author_designation">{{ section.settings.author_designation }}</span>
              {% endif %}
            </div>
          </div>
        {% endif %}
        {%- if blog.comments_enabled? -%}
          <div class="comments-container">
            <div class="comments-wrap">
              {%- if article.comments_count > 0 -%}
                <div class="comments-title">
                  <h2 class="title">
                    {{ article.comments_count }} Comment{% if article.comments_count > 1 %}s{% endif %}
                  </h2>
                </div>
                <div class="latest-comments">
                  <ul>
                    {%- assign anchorId = '#Comments-' | append: article.id -%}
                    {% paginate article.comments by 3 %}
                      {%- for comment in article.comments -%}
                        <li class="comment">
                          <div class="comment-content">
                            <div class="commment-author">
                              <div class="comment-avatar">
                                <div class="avatar-icon">
                                  <span>
                                    {{- 'icon-avatar-placeholder.svg' | inline_asset_content -}}
                                  </span>
                                </div>
                                <div class="avatar-name">
                                  <h6 class="title">{{ comment.author }}</h6>
                                </div>
                              </div>
                              <div class="commment-month">
                                <span>{{ comment.created_at | date: '%b %d, %Y' }}</span>
                              </div>
                            </div>
                            <div class="comment-desc">
                              {{ comment.content }}
                            </div>
                          </div>
                        </li>
                      {%- endfor -%}
                      {% render 'pagination', paginate: paginate, anchor: anchorId %}
                    {% endpaginate %}
                  </ul>
                </div>
              {%- endif -%}
            </div>

            <!-- Comment Form -->
            <div class="comment-respond">
              <div class="comment-header">
                <h3 class="title">{{ 'blogs.article.comment_form_title' | t }}</h3>
                <div class="comment-desc">
                  {% if blog.moderated? -%}
                   {{ 'blogs.article.moderated' | t }}
                  {%- endif %}
                  {{ 'blogs.article.moderated_captcha' | t }}
                  <a href="https://hcaptcha.com/privacy">{{ 'blogs.article.privacy_policy' | t }}</a> {{ 'blogs.article.and' | t }} <div class="h-captcha" data-sitekey="{{ settings.hcaptcha_site_key }}" data-theme="light" data-size="normal" data-type="image"></div>
            
              </div><a href="https://hcaptcha.com/terms">{{ 'blogs.article.terms_of_service' | t }}</a> {{ 'blogs.article.apply' | t }}
                </div>
              {% form 'new_comment', article %}
                <!-- Success Message -->
                {%- if form.posted_successfully? -%}
                  <div class="form-submit-status success-message" role="status">
                    <p>{{ 'blogs.article.success' | t }}</p>
                  </div>
                {%- endif -%}

                <div class="comment_details_form">
                  <div class="form-input">
                    <label for="CommentForm-author">{{ 'blogs.article.name' | t }} <span>*</span></label>
                    <input
                      type="text"
                      id="CommentForm-author"
                      name="comment[author]"
                      placeholder="{{ 'blogs.article.name_placeholder' | t }}"
                      required
                    >
                  </div>
                  <div class="form-input">
                    <label for="CommentForm-email">{{ 'blogs.article.email' | t }} <span>*</span></label>
                    <input
                      type="email"
                      id="CommentForm-email"
                      name="comment[email]"
                      placeholder="{{ 'blogs.article.email_placeholder' | t }}"
                      required
                    >
                  </div>
                  <div class="form-input comment-textarea">
                    <label for="CommentForm-body">{{ 'blogs.article.message' | t }} <span>*</span></label>
                    <textarea id="CommentForm-body" name="comment[body]" placeholder="{{ 'blogs.article.message_placeholder' | t }}"></textarea>
                  </div>
                  <div class="form-info w-full">
                    <p>* {{ 'blogs.article.required' | t }}</p>
                  </div>
                  <button class="snazzy-icon-btn btn-with-border uppercase submit-btn" type="submit">
                    {{ 'blogs.article.apply' | t }} <span>{{- 'icon-caret.svg' | inline_asset_content -}}</span>
                  </button>
                </div>
              {% endform %}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
<script type="application/ld+json">
  {{ article | structured_data }}
</script>
{% schema %}
{
  "name": "t:sections.main-article.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 120
    },
        {
      "type": "header",
      "content": "Article"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "t:sections.main-article.settings.show_breadcrumb.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:sections.main-article.settings.show_date.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tag",
      "label": "t:sections.main-article.settings.show_tag.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social_share",
      "label": "t:sections.main-article.settings.show_social_share.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main-article.settings.author_info_header"
    },
    {
      "type": "checkbox",
      "id": "show_author_information",
      "label": "t:sections.main-article.settings.show_author_information.label",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "t:sections.main-article.settings.author_image.label"
    },
    {
      "type": "text",
      "id": "author_designation",
      "label": "t:sections.main-article.settings.author_designation.label",
      "default": "Fashion Blogger",
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "main_padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 120
    },
    {
      "type": "range",
      "id": "main_padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 120
    }
  ]
}
{% endschema %}
