{{ 'component-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'accordion-item.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.67 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% assign opened_category = false %}
{% assign default_category_opened = false %}
<section class="faq-main-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} {% if section.settings.enable_corner_round %}corner-round{% endif %}">
  <div class="page-width">
    <div class="faq_main_wrapper">
      {% if section.settings.left_title != blank or section.settings.left_paragraph != blank %}
        <div class="faq_left_content">
          <h3 class="faq_left_title">{{ section.settings.left_title }}</h3>
          <div class="faq_left_desc">
            <div class="faq__desc">{{ section.settings.left_paragraph }}</div>
          </div>
        </div>
      {% endif %}

      <div class="accordion_main_content">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'faq_category_title' %}
              {% if opened_category or default_category_opened %}
                </div>
              {% endif %}
              <div class="accordion faq_tabs">
                <h4 class="faq_title" {{ block.shopify_attributes }}>{{ block.settings.category_title }}</h4>
                {% assign opened_category = true %}
                {% assign default_category_opened = false %}
            {% when 'faq_item' %}
              {% unless opened_category %}
                {% unless default_category_opened %}
                  <div class="accordion faq_tabs">
                    {% assign default_category_opened = true %}
                {% endunless %}
              {% endunless %}
              <accordion-item>
                <div class="accordion-wrapper" {{ block.shopify_attributes }}>
                  <button id="accordion-button-{{ forloop.index }}" aria-expanded="false">
                    <span class="accordion-title">{{ block.settings.question }}</span>
                    <span class="icon" aria-hidden="true"></span>
                  </button>
                  <div class="accordion_content">
                    <p class="accordion_desc">{{ block.settings.answer }}</p>
                  </div>
                </div>
              </accordion-item>
          {% endcase %}
        {% endfor %}
        {% if opened_category or default_category_opened %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.faq.name",
  "tag": "section",
  "class": "faq-main-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    // {
    //   "type": "checkbox",
    //   "id": "enable_corner_round",
    //   "label": "t:sections.all.corner_rounding.label",
    //   "default": true
    // },
    {
      "type": "text",
      "id": "left_title",
      "label": "t:sections.faq.settings.left_title.label",
      "default": "t:sections.faq.settings.left_title.default"
    },
    {
      "type": "richtext",
      "id": "left_paragraph",
      "label": "t:sections.faq.settings.left_paragraph.label",
      "default": "t:sections.faq.settings.left_paragraph.default"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 120
    }
  ],
  "blocks": [
    {
      "type": "faq_category_title",
      "name": "t:sections.faq.blocks.faq_category_title.name",
      "settings": [
        {
          "type": "text",
          "id": "category_title",
          "label": "t:sections.faq.blocks.faq_category_title.settings.category_title.label",
          "default": "t:sections.faq.blocks.faq_category_title.settings.category_title.default"
        }
      ]
    },
    {
      "type": "faq_item",
      "name": "t:sections.faq.blocks.faq_item.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.faq.blocks.faq_item.settings.question.label",
          "default": "t:sections.faq.blocks.faq_item.settings.question.default"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:sections.faq.blocks.faq_item.settings.answer.label",
          "default": "t:sections.faq.blocks.faq_item.settings.answer.default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.presets.name",
      "category": "t:sections.faq.presets.category",
      "blocks": [
        { "type": "faq_category_title" },
        { "type": "faq_item" },
        { "type": "faq_category_title" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}
