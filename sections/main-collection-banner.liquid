{{ 'page-header.css' | asset_url | stylesheet_tag }}

{%- style -%}

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.65 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}


<section class="page-header breadcrumb-main-area section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
    <div class="breadcrumb-content-area page-width">
      <div class="breadcrumb-content-area-inner">
        <div class="breadcrumb-link">
          <ul>
              <li><a href="{{ routes.root_url }}">Home</a></li>
              <li><a href="{{ shop.url }}/collections/all">Shop</a></li>
              <li>{{ collection.title }}</li>
          </ul>
        </div>
        <div class="breadcrumb-heading">
        {% if section.settings.section_heading != blank %}
          <h1 class="breadcrumb-title">{{ section.settings.section_heading }}</h1>
          {% else %}
          <h1 class="breadcrumb-title">{{ collection.title }}</h1>
        {% endif %}
        </div>
      </div>
    </div>
    {% if section.settings.header_bg %}
      <div class="page-header-bg">
        <img src="{{ section.settings.header_bg | image_url: width: 533 }}" loading="lazy" width="{{ section.settings.header_bg.width }}" height="{{ section.settings.header_bg.height }}" >
      </div>
    {% endif %}
</section>




{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "header_bg",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Page heading",
      "info": "Leave it blank to show the default heading." 
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 200
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 200
    },




    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label",
      "info": "t:sections.main-collection-banner.settings.show_collection_image.info"
    }
  ]
}
{% endschema %}
