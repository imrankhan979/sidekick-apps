{% doc %}
  @prompt
    Create an original editorial grid section with a compelling section headline (max 8 words). Include 3-6 grid items, each with a high-quality image, short headline (2-5 words), brief 1-2 sentence description, optional category tag/label, and an optional link. The grid should be fully responsive — adapting from a single column on mobile to 2 columns on tablet and 3 columns on desktop. Design with unique spacing, strong visual hierarchy, and a professional editorial feel. Use clean typography with clear heading/image/text relationships, balanced proportions, and crisp imagery. The overall tone should feel like a premium content curation layout — distinct, polished, and engaging.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-grid-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-editorial-grid__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .ai-editorial-grid__header-{{ ai_gen_id }} {
    margin-bottom: 48px;
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-editorial-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
  }

  .ai-editorial-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap_mobile }}px;
  }

  .ai-editorial-grid__item-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-editorial-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-editorial-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-editorial-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-grid__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-editorial-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-editorial-grid__category-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 14px;
    background-color: {{ block.settings.category_background }};
    color: {{ block.settings.category_text_color }};
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 2px;
    z-index: 2;
  }

  .ai-editorial-grid__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .ai-editorial-grid__item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    color: {{ block.settings.item_title_color }};
    letter-spacing: -0.01em;
  }

  .ai-editorial-grid__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  .ai-editorial-grid__link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    text-indent: -9999px;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-grid__container-{{ ai_gen_id }} {
      padding: 80px 40px;
    }

    .ai-editorial-grid__header-{{ ai_gen_id }} {
      margin-bottom: 64px;
    }

    .ai-editorial-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .ai-editorial-grid__container-{{ ai_gen_id }} {
      padding: 100px 60px;
    }

    .ai-editorial-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.grid_gap_desktop }}px;
    }
  }
{% endstyle %}

<editorial-grid-{{ ai_gen_id }} class="ai-editorial-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-grid__container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <div class="ai-editorial-grid__header-{{ ai_gen_id }}">
        <h2 class="ai-editorial-grid__title-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
      </div>
    {% endif %}

    <div class="ai-editorial-grid__grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign item_enabled_key = 'item_' | append: i | append: '_enabled'
          assign item_image_key = 'item_' | append: i | append: '_image'
          assign item_category_key = 'item_' | append: i | append: '_category'
          assign item_title_key = 'item_' | append: i | append: '_title'
          assign item_description_key = 'item_' | append: i | append: '_description'
          assign item_link_key = 'item_' | append: i | append: '_link'

          assign item_enabled = block.settings[item_enabled_key]
          assign item_image = block.settings[item_image_key]
          assign item_category = block.settings[item_category_key]
          assign item_title = block.settings[item_title_key]
          assign item_description = block.settings[item_description_key]
          assign item_link = block.settings[item_link_key]
        %}

        {% if item_enabled %}
          <article class="ai-editorial-grid__item-{{ ai_gen_id }}">
            <div class="ai-editorial-grid__image-wrapper-{{ ai_gen_id }}">
              {% if item_image != blank %}
                <img
                  src="{{ item_image | image_url: width: 800 }}"
                  alt="{{ item_image.alt | escape }}"
                  loading="lazy"
                  width="{{ item_image.width }}"
                  height="{{ item_image.height }}"
                  class="ai-editorial-grid__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-editorial-grid__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if item_category != blank %}
                <span class="ai-editorial-grid__category-{{ ai_gen_id }}">{{ item_category }}</span>
              {% endif %}
            </div>

            <div class="ai-editorial-grid__content-{{ ai_gen_id }}">
              {% if item_title != blank %}
                <h3 class="ai-editorial-grid__item-title-{{ ai_gen_id }}">{{ item_title }}</h3>
              {% endif %}

              {% if item_description != blank %}
                <p class="ai-editorial-grid__description-{{ ai_gen_id }}">{{ item_description }}</p>
              {% endif %}
            </div>

            {% if item_link != blank %}
              <a
                href="{{ item_link }}"
                class="ai-editorial-grid__link-{{ ai_gen_id }}"
                aria-label="{{ item_title | escape }}"
              >
                {{- item_title -}}
              </a>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</editorial-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('editorial-grid-{{ ai_gen_id }}', EditorialGrid{{ ai_gen_id }});
  })();
</script>

