{% doc %}
  @prompt
    Create a text marquee carousel section that scrolls text continuously across the screen. Include:- A headline/section title above the marquee (max 10 words)- Primary scrolling marquee text (1-2 sentences) that loops seamlessly without visible breaks- A secondary accent text line (tagline or subtitle) as an optional second scrolling row- Customization settings for: scroll speed (slow/medium/fast), scroll direction (left-to-right or right-to-left), font size (responsive: 24-48px desktop, 16-24px mobile), text color (high-contrast), and background color or gradient- Smooth, continuous CSS animation with no stuttering or visible gaps between loops- Fully responsive layout that looks great on desktop, tablet, and mobile- Eye-catching design suitable for announcements, promotions, or brand messaging
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
    overflow: hidden;
  }

  .ai-marquee-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
    padding: 0 20px;
  }

  .ai-marquee-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    gap: {{ block.settings.text_spacing }}px;
    {% if block.settings.scroll_direction == 'left' %}
      animation: ai-marquee-scroll-left-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    {% else %}
      animation: ai-marquee-scroll-right-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    {% endif %}
  }

  .ai-marquee-track-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-marquee-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.primary_font_size }}px;
    color: {{ block.settings.primary_text_color }};
    white-space: nowrap;
    font-weight: 500;
    line-height: 1.2;
  }

  .ai-marquee-secondary-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.secondary_spacing }}px;
  }

  .ai-marquee-secondary-track-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    gap: {{ block.settings.text_spacing }}px;
    {% if block.settings.secondary_scroll_direction == 'left' %}
      animation: ai-marquee-scroll-left-{{ ai_gen_id }} {{ block.settings.secondary_scroll_speed }}s linear infinite;
    {% else %}
      animation: ai-marquee-scroll-right-{{ ai_gen_id }} {{ block.settings.secondary_scroll_speed }}s linear infinite;
    {% endif %}
  }

  .ai-marquee-secondary-track-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-marquee-secondary-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.secondary_font_size }}px;
    color: {{ block.settings.secondary_text_color }};
    white-space: nowrap;
    font-weight: 400;
    line-height: 1.2;
  }

  @keyframes ai-marquee-scroll-left-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @keyframes ai-marquee-scroll-right-{{ ai_gen_id }} {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.7 }}px;
    }

    .ai-marquee-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.primary_font_size | times: 0.6 }}px;
    }

    .ai-marquee-secondary-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.secondary_font_size | times: 0.6 }}px;
    }
  }
{% endstyle %}

<text-marquee-{{ ai_gen_id }} class="ai-marquee-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_title != blank %}
    <div class="ai-marquee-header-{{ ai_gen_id }}">
      <h2 class="ai-marquee-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    </div>
  {% endif %}

  <div class="ai-marquee-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-track-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        <span class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.primary_text }}</span>
      {% endfor %}
    </div>
  </div>

  {% if block.settings.enable_secondary and block.settings.secondary_text != blank %}
    <div class="ai-marquee-secondary-wrapper-{{ ai_gen_id }}">
      <div class="ai-marquee-secondary-track-{{ ai_gen_id }}">
        {% for i in (1..10) %}
          <span class="ai-marquee-secondary-text-{{ ai_gen_id }}">{{ block.settings.secondary_text }}</span>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</text-marquee-{{ ai_gen_id }}>

<script>
  (function() {
    class TextMarquee{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupMarquee();
      }

      setupMarquee() {
        const tracks = this.querySelectorAll('.ai-marquee-track-{{ ai_gen_id }}, .ai-marquee-secondary-track-{{ ai_gen_id }}');

        tracks.forEach((track) => {
          const firstItem = track.querySelector('span');
          if (firstItem) {
            const itemWidth = firstItem.offsetWidth;
            const gap = {{ block.settings.text_spacing }};
            const totalWidth = (itemWidth + gap) * 5;
            track.style.width = totalWidth + 'px';
          }
        });
      }
    }

    customElements.define('text-marquee-{{ ai_gen_id }}', TextMarquee{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Text marquee",
  "settings": [
    {
      "type": "header",
      "content": "Section title"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "label": "Title",
      "default": "Special Announcement"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Title spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Primary marquee"
    },
    {
      "type": "textarea",
      "id": "primary_text",
      "label": "Primary text",
      "default": "Limited time offer - Free shipping on all orders over $50 - Shop now and save big!"
    },
    {
      "type": "range",
      "id": "primary_font_size",
      "label": "Font size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "primary_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "scroll_direction",
      "label": "Scroll direction",
      "options": [
        {
          "value": "left",
          "label": "Left to right"
        },
        {
          "value": "right",
          "label": "Right to left"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "options": [
        {
          "value": "40",
          "label": "Slow"
        },
        {
          "value": "25",
          "label": "Medium"
        },
        {
          "value": "15",
          "label": "Fast"
        }
      ],
      "default": "25"
    },
    {
      "type": "header",
      "content": "Secondary marquee"
    },
    {
      "type": "checkbox",
      "id": "enable_secondary",
      "label": "Enable secondary marquee",
      "default": true
    },
    {
      "type": "textarea",
      "id": "secondary_text",
      "label": "Secondary text",
      "default": "New arrivals every week - Join our VIP club for exclusive deals"
    },
    {
      "type": "range",
      "id": "secondary_font_size",
      "label": "Font size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "secondary_text_color",
      "label": "Text color",
      "default": "#666666"
    },
    {
      "type": "select",
      "id": "secondary_scroll_direction",
      "label": "Scroll direction",
      "options": [
        {
          "value": "left",
          "label": "Left to right"
        },
        {
          "value": "right",
          "label": "Right to left"
        }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "secondary_scroll_speed",
      "label": "Scroll speed",
      "options": [
        {
          "value": "40",
          "label": "Slow"
        },
        {
          "value": "25",
          "label": "Medium"
        },
        {
          "value": "15",
          "label": "Fast"
        }
      ],
      "default": "25"
    },
    {
      "type": "range",
      "id": "secondary_spacing",
      "label": "Spacing from primary",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Text spacing",
      "min": 20,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Text marquee"
    }
  ]
}
{% endschema %}
