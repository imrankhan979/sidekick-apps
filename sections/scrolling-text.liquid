{{ 'scrolling-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .id-{{ section.id }} .snzz-video-img::before{
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}


<section class="marquee-section color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="marquee_slider section-{{ section.id }}-padding">
      <div class="marquee_wrapper marquee_box_revers" style="--scroll-duration: {{ section.settings.scroll_duration }}s">
        {% assign block_count = section.blocks.size %}

        {% if block_count < 3 %}
          {% assign repeat_count = 10 %}
        {% else %}
          {% assign repeat_count = 1 %} 
        {% endif %}

        {% for i in (1..repeat_count) %} 
          {% for block in section.blocks %}
            {% if block.type == 'marquee_item' %}
              <div class="marquee_item" {{ block.shopify_attributes }}>
                <div class="marquee_title">
                  <h3 class="title">{{ block.settings.title }}</h3>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endfor %}

        {% for i in (1..repeat_count) %} 
          {% for block in section.blocks %}
            {% if block.type == 'marquee_item' %}
              <div class="marquee_item" {{ block.shopify_attributes }}>
                <div class="marquee_title">
                  <h3 class="title">{{ block.settings.title }}</h3>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>

      <div class="marquee_wrapper marquee_box_revers" style="--scroll-duration: {{ section.settings.scroll_duration }}s">
        {% assign block_count = section.blocks.size %}

        {% if block_count < 3 %}
          {% assign repeat_count = 5 %}
        {% else %}
          {% assign repeat_count = 1 %} 
        {% endif %}

        {% for i in (1..repeat_count) %} 
          {% for block in section.blocks %}
            {% if block.type == 'marquee_item' %}
              <div class="marquee_item" {{ block.shopify_attributes }}>
                <div class="marquee_title">
                  <h3 class="title">{{ block.settings.title }}</h3>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endfor %}

        {% for i in (1..repeat_count) %}
          {% for block in section.blocks %}
            {% if block.type == 'marquee_item' %}
              <div class="marquee_item" {{ block.shopify_attributes }}>
                <div class="marquee_title">
                  <h3 class="title">{{ block.settings.title }}</h3>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>
    </div>

    <div class="marquee_sm_slider">
      <items-carousel>
          <div class="scroll_text_carousel items-carousel-selector" data-flickity='{"contain": true, "prevNextButtons": false, "pageDots": true }'>
            {% for block in section.blocks %}
              {% if block.type == 'marquee_item' %}
                <div class="marquee_item" {{ block.shopify_attributes }}>
                  <div class="marquee_title">
                    <h3 class="title">{{ block.settings.title }}</h3>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
      </items-carousel>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Marquee",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "t:sections.all.colors.label",
            "info": "t:sections.all.colors.has_cards_info",
            "default": "scheme-1"
        },
        {
            "type": "number",
            "id": "scroll_duration",
            "label": "Scroll duration (seconds)",
            "default": 60
        },
        {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 120,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.padding.padding_top",
            "default": 76
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "min": 0,
            "max": 120,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.padding.padding_bottom",
            "default": 76
        }
    ],
    "blocks": [
      {
        "type": "marquee_item",
        "name": "Marquee Item",
        "settings": [
         {
            "type": "text",
            "id": "title",
            "label": "Text"
          }
        ]
      }
    ],
    "presets": [
        {
            "name": "Marquee",
            "blocks": [
                {"type": "marquee_item", "settings": {"title": "Worldwide Delivery"}},
                {"type": "marquee_item", "settings": {"title": "Flexible Payment"}},
                {"type": "marquee_item", "settings": {"title": "30-Day Free Return"}},
                {"type": "marquee_item", "settings": {"title": "Quick Support 24/7"}}
            ]
        }
    ]
  }
{% endschema %}