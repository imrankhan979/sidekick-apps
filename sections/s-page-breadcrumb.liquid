{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section class="breadcrumb-main-area section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="breadcrumb-content-area">
      <div class="anim-item breadcrumb-link">
        <ul>
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li>{{ page.title | escape }}</li>
        </ul>
      </div>
      <div class="anim-item breadcrumb-heading">
        <h1 class="breadcrumb-title">
          {% if section.settings.custom_text != blank %}
            {{ section.settings.custom_text }}
          {% else %}
            {{ page.title | escape }}
          {% endif %}
        </h1>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Breadcrumb banner",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "custom_text",
      "label": "Custom title page"
    },
    {
      "type": "checkbox",
      "id": "enable_breadcrumb_navigation",
      "default": true,
      "label": "Enable breadcrumb navigation"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 200
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 250
    }
  ]
}
{% endschema %}
