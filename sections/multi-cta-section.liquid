{% doc %}
  @prompt
    Create a multi-CTA section with a headline and 3 call-to-action option cards in a horizontal grid layout. Each card should include an icon or visual, a short heading (3-5 words), a one-sentence description, and a button with a link. The first card (primary) should be visually highlighted with a distinct background color or border. Example options: "Browse Products", "Contact Support", and "View FAQ". The section should have a centered headline like "What would you like to do?" above the cards. Cards should be evenly spaced in a responsive 3-column grid that stacks on mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multi-cta-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-multi-cta__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-multi-cta__headline-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    color: {{ block.settings.headline_color }};
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 600;
  }

  .ai-multi-cta__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-multi-cta__card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ai-multi-cta__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-multi-cta__card--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_card_background }};
    border-color: {{ block.settings.primary_card_border_color }};
    border-width: {{ block.settings.primary_card_border_width }}px;
  }

  .ai-multi-cta__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-multi-cta__icon-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-multi-cta__card--primary-{{ ai_gen_id }} .ai-multi-cta__icon-wrapper-{{ ai_gen_id }} svg {
    fill: {{ block.settings.primary_icon_color }};
  }

  .ai-multi-cta__card-heading-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: {{ block.settings.card_heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.card_heading_color }};
  }

  .ai-multi-cta__card--primary-{{ ai_gen_id }} .ai-multi-cta__card-heading-{{ ai_gen_id }} {
    color: {{ block.settings.primary_card_heading_color }};
  }

  .ai-multi-cta__card-description-{{ ai_gen_id }} {
    margin: 0 0 20px;
    font-size: {{ block.settings.card_description_size }}px;
    line-height: 1.5;
    color: {{ block.settings.card_description_color }};
  }

  .ai-multi-cta__card--primary-{{ ai_gen_id }} .ai-multi-cta__card-description-{{ ai_gen_id }} {
    color: {{ block.settings.primary_card_description_color }};
  }

  .ai-multi-cta__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: background-color 0.2s ease, color 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .ai-multi-cta__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-multi-cta__card--primary-{{ ai_gen_id }} .ai-multi-cta__button-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_background }};
    color: {{ block.settings.primary_button_text_color }};
  }

  .ai-multi-cta__card--primary-{{ ai_gen_id }} .ai-multi-cta__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_background }};
    color: {{ block.settings.primary_button_hover_text_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-multi-cta__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-multi-cta__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-multi-cta__card-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_heading_size | times: 0.9 }}px;
    }

    .ai-multi-cta__card-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<multi-cta-section-{{ ai_gen_id }} class="ai-multi-cta-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multi-cta__container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-multi-cta__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    <div class="ai-multi-cta__grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign card_enabled_key = 'card_' | append: i | append: '_enabled'
          assign card_heading_key = 'card_' | append: i | append: '_heading'
          assign card_description_key = 'card_' | append: i | append: '_description'
          assign card_button_text_key = 'card_' | append: i | append: '_button_text'
          assign card_button_link_key = 'card_' | append: i | append: '_button_link'
          assign card_icon_key = 'card_' | append: i | append: '_icon'

          assign card_enabled = block.settings[card_enabled_key]
          assign card_heading = block.settings[card_heading_key]
          assign card_description = block.settings[card_description_key]
          assign card_button_text = block.settings[card_button_text_key]
          assign card_button_link = block.settings[card_button_link_key]
          assign card_icon = block.settings[card_icon_key]
        %}

        {% if card_enabled %}
          <div class="ai-multi-cta__card-{{ ai_gen_id }} {% if i == 1 %}ai-multi-cta__card--primary-{{ ai_gen_id }}{% endif %}">
            <div class="ai-multi-cta__icon-wrapper-{{ ai_gen_id }}">
              {% case card_icon %}
                {% when 'shopping_bag' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <path d="M16 10a4 4 0 0 1-8 0"></path>
                  </svg>
                {% when 'support' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                  </svg>
                {% when 'document' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                  </svg>
                {% when 'star' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {% when 'heart' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                  </svg>
                {% when 'gift' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 12 20 22 4 22 4 12"></polyline>
                    <rect x="2" y="7" width="20" height="5"></rect>
                    <line x1="12" y1="22" x2="12" y2="7"></line>
                    <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                    <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                  </svg>
              {% endcase %}
            </div>

            {% if card_heading != blank %}
              <h3 class="ai-multi-cta__card-heading-{{ ai_gen_id }}">{{ card_heading }}</h3>
            {% endif %}

            {% if card_description != blank %}
              <p class="ai-multi-cta__card-description-{{ ai_gen_id }}">{{ card_description }}</p>
            {% endif %}

            {% if card_button_text != blank %}
              <a href="{{ card_button_link }}" class="ai-multi-cta__button-{{ ai_gen_id }}">
                {{ card_button_text }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</multi-cta-section-{{ ai_gen_id }}>

<script>
  (function() {
    class MultiCtaSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('multi-cta-section-{{ ai_gen_id }}', MultiCtaSection{{ ai_gen_id }});
  })();
</script>

