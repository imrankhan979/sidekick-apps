{% doc %}
  @prompt
    Create a social proof section with the headline "Join Thousands of Happy Customers". Include a scrolling or static grid of recent customer activity items, each showing: customer first name and last initial (for privacy), action taken (e.g., "Purchased [Product]" or "Reviewed [Product]"), a relative timestamp (e.g., "2 hours ago", "Just now"), an optional product thumbnail image, and an optional location or note. Add a metrics/counter bar displaying stats like "50,000  happy customers" and "1,000  purchases this month". Include a gentle scroll or fade animation for the activity feed to create urgency and a community feeling. All content should be customizable via theme editor settings.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-social-proof-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-social-proof-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-social-proof-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-social-proof-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-social-proof-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-social-proof-metrics-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    padding: 30px 20px;
    background-color: {{ block.settings.metrics_bg_color }};
    border-radius: {{ block.settings.metrics_border_radius }}px;
  }

  .ai-social-proof-metric-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-social-proof-metric-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.metric_number_size }}px;
    font-weight: 700;
    color: {{ block.settings.metric_number_color }};
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .ai-social-proof-metric-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.metric_label_size }}px;
    color: {{ block.settings.metric_label_color }};
    margin: 0;
  }

  .ai-social-proof-feed-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .ai-social-proof-feed-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: 16px;
  }

  .ai-social-proof-feed-{{ ai_gen_id }}.scrolling {
    display: flex;
    gap: 16px;
    animation: ai-social-proof-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-social-proof-feed-{{ ai_gen_id }}.scrolling .ai-social-proof-item-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.item_width }}px;
  }

  @keyframes ai-social-proof-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-{{ block.settings.item_width }}px * {{ block.settings.activity_items_count }} - 16px * {{ block.settings.activity_items_count }}));
    }
  }

  .ai-social-proof-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.item_bg_color }};
    border: 1px solid {{ block.settings.item_border_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    padding: 16px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    opacity: 0;
    animation: ai-social-proof-fade-in-{{ ai_gen_id }} 0.5s ease-out forwards;
  }

  @keyframes ai-social-proof-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-social-proof-item-{{ ai_gen_id }}:nth-child(1) { animation-delay: 0s; }
  .ai-social-proof-item-{{ ai_gen_id }}:nth-child(2) { animation-delay: 0.1s; }
  .ai-social-proof-item-{{ ai_gen_id }}:nth-child(3) { animation-delay: 0.2s; }
  .ai-social-proof-item-{{ ai_gen_id }}:nth-child(4) { animation-delay: 0.3s; }
  .ai-social-proof-item-{{ ai_gen_id }}:nth-child(5) { animation-delay: 0.4s; }
  .ai-social-proof-item-{{ ai_gen_id }}:nth-child(6) { animation-delay: 0.5s; }

  .ai-social-proof-item-image-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .ai-social-proof-item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-social-proof-item-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-social-proof-item-image-placeholder-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    opacity: 0.3;
  }

  .ai-social-proof-item-content-{{ ai_gen_id }} {
    flex-grow: 1;
    min-width: 0;
  }

  .ai-social-proof-item-name-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.item_text_color }};
    margin: 0 0 4px;
  }

  .ai-social-proof-item-action-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.item_action_color }};
    margin: 0 0 4px;
    line-height: 1.4;
  }

  .ai-social-proof-item-meta-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-social-proof-item-time-{{ ai_gen_id }},
  .ai-social-proof-item-location-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.item_meta_color }};
  }

  .ai-social-proof-item-time-{{ ai_gen_id }}::before {
    content: "🕐 ";
  }

  .ai-social-proof-item-location-{{ ai_gen_id }}::before {
    content: "📍 ";
  }

  @media screen and (max-width: 749px) {
    .ai-social-proof-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-social-proof-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-social-proof-metrics-{{ ai_gen_id }} {
      gap: 24px;
    }

    .ai-social-proof-metric-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.metric_number_size }}px * 0.8);
    }

    .ai-social-proof-feed-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-social-proof-feed-{{ ai_gen_id }}.scrolling .ai-social-proof-item-{{ ai_gen_id }} {
      flex: 0 0 280px;
    }
  }
{% endstyle %}

<social-proof-{{ ai_gen_id }} class="ai-social-proof-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-social-proof-container-{{ ai_gen_id }}">
    <div class="ai-social-proof-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-social-proof-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-social-proof-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    {% if block.settings.show_metrics %}
      <div class="ai-social-proof-metrics-{{ ai_gen_id }}">
        {% if block.settings.metric_1_number != blank %}
          <div class="ai-social-proof-metric-{{ ai_gen_id }}">
            <div class="ai-social-proof-metric-number-{{ ai_gen_id }}">{{ block.settings.metric_1_number }}</div>
            <div class="ai-social-proof-metric-label-{{ ai_gen_id }}">{{ block.settings.metric_1_label }}</div>
          </div>
        {% endif %}

        {% if block.settings.metric_2_number != blank %}
          <div class="ai-social-proof-metric-{{ ai_gen_id }}">
            <div class="ai-social-proof-metric-number-{{ ai_gen_id }}">{{ block.settings.metric_2_number }}</div>
            <div class="ai-social-proof-metric-label-{{ ai_gen_id }}">{{ block.settings.metric_2_label }}</div>
          </div>
        {% endif %}

        {% if block.settings.metric_3_number != blank %}
          <div class="ai-social-proof-metric-{{ ai_gen_id }}">
            <div class="ai-social-proof-metric-number-{{ ai_gen_id }}">{{ block.settings.metric_3_number }}</div>
            <div class="ai-social-proof-metric-label-{{ ai_gen_id }}">{{ block.settings.metric_3_label }}</div>
          </div>
        {% endif %}

        {% if block.settings.metric_4_number != blank %}
          <div class="ai-social-proof-metric-{{ ai_gen_id }}">
            <div class="ai-social-proof-metric-number-{{ ai_gen_id }}">{{ block.settings.metric_4_number }}</div>
            <div class="ai-social-proof-metric-label-{{ ai_gen_id }}">{{ block.settings.metric_4_label }}</div>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-social-proof-feed-wrapper-{{ ai_gen_id }}">
      <div
        class="ai-social-proof-feed-{{ ai_gen_id }} {% if block.settings.enable_scrolling %}scrolling{% endif %}"
        data-feed
      >
        {% for i in (1..6) %}
          {% liquid
            assign name_key = 'activity_' | append: i | append: '_name'
            assign action_key = 'activity_' | append: i | append: '_action'
            assign time_key = 'activity_' | append: i | append: '_time'
            assign location_key = 'activity_' | append: i | append: '_location'
            assign image_key = 'activity_' | append: i | append: '_image'

            assign name = block.settings[name_key]
            assign action = block.settings[action_key]
            assign time = block.settings[time_key]
            assign location = block.settings[location_key]
            assign image = block.settings[image_key]
          %}

          {% if name != blank and action != blank %}
            <div class="ai-social-proof-item-{{ ai_gen_id }}">
              <div class="ai-social-proof-item-image-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 100 }}"
                    alt="{{ name }}"
                    width="50"
                    height="50"
                    loading="lazy"
                  >
                {% else %}
                  <div class="ai-social-proof-item-image-placeholder-{{ ai_gen_id }}">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                      <circle cx="8.5" cy="8.5" r="1.5"></circle>
                      <polyline points="21 15 16 10 5 21"></polyline>
                    </svg>
                  </div>
                {% endif %}
              </div>
              <div class="ai-social-proof-item-content-{{ ai_gen_id }}">
                <div class="ai-social-proof-item-name-{{ ai_gen_id }}">{{ name }}</div>
                <div class="ai-social-proof-item-action-{{ ai_gen_id }}">{{ action }}</div>
                <div class="ai-social-proof-item-meta-{{ ai_gen_id }}">
                  {% if time != blank %}
                    <span class="ai-social-proof-item-time-{{ ai_gen_id }}">{{ time }}</span>
                  {% endif %}
                  {% if location != blank %}
                    <span class="ai-social-proof-item-location-{{ ai_gen_id }}">{{ location }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</social-proof-{{ ai_gen_id }}>

<script>
  (function() {
    class SocialProof{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const feed = this.querySelector('[data-feed]');

        if (feed && feed.classList.contains('scrolling')) {
          this.setupScrolling(feed);
        }
      }

      setupScrolling(feed) {
        const items = Array.from(feed.children);
        const clonedItems = items.map(item => item.cloneNode(true));

        clonedItems.forEach(clone => {
          feed.appendChild(clone);
        });

        feed.addEventListener('mouseenter', () => {
          feed.style.animationPlayState = 'paused';
        });

        feed.addEventListener('mouseleave', () => {
          feed.style.animationPlayState = 'running';
        });
      }
    }

    customElements.define('social-proof-{{ ai_gen_id }}', SocialProof{{ ai_gen_id }});
  })();
</script>

