{{ 'slideshow.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="banner-slider slider-section color-{{ section.settings.section_color_scheme }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="slider_wrapper">
      <items-carousel>
        <div class="carousel items-carousel-selector" data-flickity='{"prevNextButtons": true, "pageDots": true}'>
          {% for block in section.blocks %}
            <div class="slider_item" {{ block.shopify_attributes }}>
              <div class="slider-images" style="width: {{ block.settings.image_max_width }}%;">
                {% if block.settings.image %}
                  <img src="{{ block.settings.image | img_url: 'master' }}" width="" height="" alt="Slide Image">
                {% else %}
                  
                {% endif %} 
              </div>
              <div class="slider_item_content" style="width: calc(100% - {{ block.settings.image_max_width }}%);">
                <h1 class="slider_title">
                  {{ block.settings.title | newline_to_br }}
                  {% if block.settings.cta_text %}
                    <a class="active-text" href="{{ block.settings.cta_link }}">{{ block.settings.cta_text }}</a>
                  {% endif %}
                </h1>
                <div class="slider_item_text">
                  <div class="slider_item_desc">
                    <p>{{ block.settings.description }}</p>
                  </div>
                  <div class="slider_button">
                    {% if block.settings.button_text %}
                      <a class="slider-btn" href="{{ block.settings.button_link }}">{{ block.settings.button_text }} <span> {{- 'icon-arrow.svg' | inline_asset_content -}}</span></a>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </items-carousel>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Slideshow",
    "settings": [
      {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
    ],
    "blocks": [
      {
        "type": "slide",
        "name": "Slide",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Slide Image"
          },
          {
            "type": "range",
            "id": "image_max_width",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Image width",
            "default": 60
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Streetwise new way of style"
          },
          {
            "type": "text",
            "id": "cta_text",
            "label": "CTA Text",
            "default": "collection"
          },
          {
            "type": "url",
            "id": "cta_link",
            "label": "CTA Link"
          },
          {
            "type": "textarea",
            "id": "description",
            "label": "Description",
            "default": "Discover a new level of style, from bold streetwear to refined essentials."
          },
          {
            "type": "text",
            "id": "button_text",
            "label": "Button Text",
            "default": "Shop now"
          },
          {
            "type": "url",
            "id": "button_link",
            "label": "Button Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Slideshow",
        "blocks": [
          {
            "type": "slide"
          },
          {
            "type": "slide"
          }
        ]
      }
    ]
  }
  {% endschema %}
  
