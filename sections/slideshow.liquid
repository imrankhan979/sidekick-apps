{{ 'slideshow.css' | asset_url | stylesheet_tag }}

{%- style -%}
    {% for block in section.blocks %}
    .section-{{ block.id }}-padding {
      padding-top: {{ block.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ block.id }}-padding {
        padding-top: {{ block.settings.padding_top }}px;
        padding-bottom: {{ block.settings.padding_bottom }}px;
      }
    }
  {% endfor %}
{%- endstyle -%}

<section class="banner-slider slider-section color-{{ section.settings.section_color_scheme }}">
  <div class="slider_wrapper">
    <items-carousel>
      <div
        class="carousel items-carousel-selector"
        data-flickity='{"prevNextButtons":{% if section.settings.navigation %}true{% else %}false{% endif %}, "pageDots":{% if section.settings.dots %}true{% else %}false{% endif %}, "autoPlay":{% if section.settings.autoplay %}true{% else %}false{% endif %}}'
      >
        {% for block in section.blocks %}
          <div class="section-{{ block.id }}-padding slider_item" {{ block.shopify_attributes }}>
            <div
              class="slider_item_content"
            >
              {% if block.settings.title != blank %}
                <h1 class="slider_title">
                  {{ block.settings.title | newline_to_br }}
                  <div class="active-text">
                    {{- block.settings.cta_text -}}
                  </div>
                </h1>
              {% endif %}
              {% if block.settings.description != blank or block.settings.button_text != blank %}
                <div class="slider_item_text">
                  {% if block.settings.description != blank %}
                    <div class="slider_item_desc">
                      <p>{{ block.settings.description }}</p>
                    </div>
                  {% endif %}
                  {% if block.settings.button_text != blank %}
                    <div class="slider_button">
                      {% if block.settings.button_text %}
                        <a
                          class="slider-btn snazzy-icon-btn"
                          {% if block.settings.button_link == blank %}
                            role="link" aria-disabled="true"
                          {% else %}
                            href="{{ block.settings.button_link }}"
                          {% endif %}
                        >
                          {{- block.settings.button_text -}}
                          <span>{{- 'icon-caret.svg' | inline_asset_content -}}</span></a
                        >
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            <div class="bg-media">
              {% if block.settings.bg_video != blank %}
                {% assign video_url = block.settings.bg_video.sources[1].url %}
                <video
                  src="{{ video_url }}"
                  playsinline
                  muted
                  {% if block.settings.video_loop %}
                    loop
                  {% endif %}
                  {% if block.settings.video_autoplay %}
                    autoplay
                  {% endif %}
                ></video>
              {% elsif block.settings.bg_image != blank %}
                {% render 'the-img', image: block.settings.bg_image %}
              {% else %}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </items-carousel>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "navigation",
      "label": "t:sections.slideshow.settings.show_navigation_arrows.label"
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "t:sections.slideshow.settings.show_pagination_dots.label"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.slideshow.settings.autoplay.label"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.slideshow.blocks.slide.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "t:sections.slideshow.blocks.slide.settings.bg_image.label"
        },
        {
          "type": "video",
          "id": "bg_video",
          "label": "t:sections.slideshow.blocks.slide.settings.bg_video.label",
          "info": "Video overrides background image."
        },
        {
          "type": "checkbox",
          "id": "video_loop",
          "label": "t:sections.slideshow.blocks.slide.settings.video_loop.label",
          "default": true,
          "info": "t:sections.slideshow.blocks.slide.settings.video_loop.info"
        },
        {
          "type": "checkbox",
          "id": "video_autoplay",
          "label": "t:sections.slideshow.blocks.slide.settings.video_autoplay.label",
          "default": true,
          "info": "t:sections.slideshow.blocks.slide.settings.video_autoplay.info"
        },
        {
          "type": "header",
          "content": "t:sections.slideshow.blocks.slide.settings.text_header.content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.slideshow.blocks.slide.settings.title_text.label",
          "default": "t:sections.slideshow.blocks.slide.settings.title_text.default"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "t:sections.slideshow.blocks.slide.settings.cta_text.label",
          "default": "t:sections.slideshow.blocks.slide.settings.cta_text.default"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.slideshow.blocks.slide.settings.description.label",
          "default": "t:sections.slideshow.blocks.slide.settings.description.default"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "t:sections.slideshow.blocks.slide.settings.button_text.label",
          "default": "t:sections.slideshow.blocks.slide.settings.button_text.default"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.slideshow.blocks.slide.settings.button_link.label"
        },
        {
          "type": "header",
          "content": "Padding"
        },
        {
          "type": "range",
          "id": "padding_top",
          "min": 0,
          "max": 200,
          "step": 4,
          "unit": "px",
          "label": "Top",
          "default": 60
        },
        {
          "type": "range",
          "id": "padding_bottom",
          "min": 0,
          "max": 200,
          "step": 4,
          "unit": "px",
          "label": "Bottom",
          "default": 60
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.slideshow.presets.name",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
