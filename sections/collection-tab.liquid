{{ 'snazzy-collection-tab.css' | asset_url | stylesheet_tag }}
<script src="{{ 'snazzy-collection-tab.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.65 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
{% for block in section.blocks %}
  .collection-tab .product-grid-{{block.id}}{
    grid-template-columns: repeat({{block.settings.item_count}}, 1fr);
  }
{% endfor %}
{%- endstyle -%}
<section class="collection-tab section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
    <div class="tabs-section">
      <snazzy-tab>
        <div class="page-width">
            <div class="tab-header flex wrap space-between align-items-center">
              <div class="section-title">
                <h1 class="sec_title">{{ section.settings.section_heading }}</h1>
              </div>
              <div class="scroller-wrapper">
                <div class="scroll-width">
                  <div class="snazzy-tab-buttons flex wrap align-items-center no-scrollbar">
                    {% for block in section.blocks %}
                      {% assign collection = collections[block.settings.collection_handle] %}
                      {% if collection.products.size > 0 %}
                        <button  role="tab" class="snazzy-tab-button {% if forloop.first %}active{% endif %}"  {{ block.shopify_attributes }}>
                          {{ block.settings.tab_title | default: collection.title }}
                        </button>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
        </div>
        <div class="page-width">
          <div class="snazzy-tab-contents">
            {% for block in section.blocks %}
              {% assign collection = collections[block.settings.collection_handle] %}
              {% if collection.products.size > 0 %}
                <div class="snazzy-tab-content {% if forloop.first %}active{% endif %}">
                    {% assign maximum_product_show = 8 %}
                          <div class="product-grid product-grid-{{block.id}}" >        
                              {% for product in collection.products limit: maximum_product_show %}
                                  {% render "product", button: false, product: product %}
                                {% endfor %}
                          </div>
                          {% if collection.products.size > maximum_product_show %}
                              <div class="view-all-btn-wrapper flex  justify-content-center">
                                  <a class="snazzy-icon-btn" href="{{ collection.url }}">VIEW ALL <span>{{- 'icon-caret.svg' | inline_asset_content -}}</span></a>
                              </div>
                          {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </snazzy-tab>
    </div>
</section>


 


{% schema %}
{
  "name": "Collection tab",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "section_heading",
      "default": "PRODUCT",
      "label": "Section heading"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 120
    }
  ],
"blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection_handle",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title",
          "info": "Optional. Defaults to collection title."
        },
        {
          "type": "range",
          "id": "item_count",
          "min": 2,
          "max": 6,
          "step": 1,
          "label": "Number of products to show in a row",
          "default": 4
        }

      ]
    }
  ],
  "presets": [
    {
      "name": "Collection tab"
    }
  ]
}
{% endschema %}
