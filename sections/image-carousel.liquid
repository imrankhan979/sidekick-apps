{% doc %}
  @prompt
    Create a rotating image carousel/gallery section with the following specifications: Display 5-8 high-quality images (product photos, lifestyle shots, product variations). Each slide supports an image, optional text caption overlay (1 sentence), and optional clickable link. Navigation: dot indicators at bottom AND left/right arrow buttons. Auto-advance every 5 seconds. Landscape 16:9 aspect ratio with consistent height. Smooth slide transitions. Alt text support for accessibility. Semi-transparent overlay for caption readability. Mobile responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
  }

  .ai-carousel-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-carousel-slides-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    position: relative;
    min-width: 100%;
    height: 100%;
    flex-shrink: 0;
  }

  .ai-carousel-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-carousel-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-carousel-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .ai-carousel-caption-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: {{ block.settings.overlay_color }};
    padding: {{ block.settings.caption_padding }}px;
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-carousel-caption-{{ ai_gen_id }} {
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_font_size }}px;
    margin: 0;
    text-align: {{ block.settings.caption_alignment }};
  }

  .ai-carousel-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.3s ease;
  }

  .ai-carousel-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
  }

  .ai-carousel-arrow-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .ai-carousel-arrow-prev-{{ ai_gen_id }} {
    left: {{ block.settings.arrow_offset }}px;
  }

  .ai-carousel-arrow-next-{{ ai_gen_id }} {
    right: {{ block.settings.arrow_offset }}px;
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.dots_bottom_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: {{ block.settings.dots_spacing }}px;
    z-index: 10;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-carousel-dot-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-arrow-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_size | times: 0.8 }}px;
      height: {{ block.settings.arrow_size | times: 0.8 }}px;
    }

    .ai-carousel-arrow-prev-{{ ai_gen_id }} {
      left: {{ block.settings.arrow_offset | times: 0.5 }}px;
    }

    .ai-carousel-arrow-next-{{ ai_gen_id }} {
      right: {{ block.settings.arrow_offset | times: 0.5 }}px;
    }

    .ai-carousel-caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<image-carousel-{{ ai_gen_id }} class="ai-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-container-{{ ai_gen_id }}">
    <div class="ai-carousel-slides-{{ ai_gen_id }}">
      {% liquid
        assign has_slides = false
        for i in (1..8)
          assign image_key = 'slide_' | append: i | append: '_image'
          if block.settings[image_key] != blank
            assign has_slides = true
            break
          endif
        endfor
      %}

      {% if has_slides %}
        {% for i in (1..8) %}
          {% liquid
            assign image_key = 'slide_' | append: i | append: '_image'
            assign caption_key = 'slide_' | append: i | append: '_caption'
            assign link_key = 'slide_' | append: i | append: '_link'
            assign alt_key = 'slide_' | append: i | append: '_alt_text'

            assign slide_image = block.settings[image_key]
            assign slide_caption = block.settings[caption_key]
            assign slide_link = block.settings[link_key]
            assign slide_alt = block.settings[alt_key]
          %}

          {% if slide_image != blank %}
            <div class="ai-carousel-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
              {% if slide_link != blank %}
                <a href="{{ slide_link }}" class="ai-carousel-link-{{ ai_gen_id }}">
                  <img
                    src="{{ slide_image | image_url: width: 2000 }}"
                    alt="{% if slide_alt != blank %}{{ slide_alt | escape }}{% else %}{{ slide_image.alt | escape }}{% endif %}"
                    loading="lazy"
                    width="{{ slide_image.width }}"
                    height="{{ slide_image.height }}"
                  >
                  {% if slide_caption != blank %}
                    <div class="ai-carousel-caption-overlay-{{ ai_gen_id }}">
                      <p class="ai-carousel-caption-{{ ai_gen_id }}">{{ slide_caption }}</p>
                    </div>
                  {% endif %}
                </a>
              {% else %}
                <img
                  src="{{ slide_image | image_url: width: 2000 }}"
                  alt="{% if slide_alt != blank %}{{ slide_alt | escape }}{% else %}{{ slide_image.alt | escape }}{% endif %}"
                  loading="lazy"
                  width="{{ slide_image.width }}"
                  height="{{ slide_image.height }}"
                >
                {% if slide_caption != blank %}
                  <div class="ai-carousel-caption-overlay-{{ ai_gen_id }}">
                    <p class="ai-carousel-caption-{{ ai_gen_id }}">{{ slide_caption }}</p>
                  </div>
                {% endif %}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-carousel-slide-{{ ai_gen_id }}">
          <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-carousel-empty-state-{{ ai_gen_id }}">Next, add images to your carousel</div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if has_slides %}
      <button
        class="ai-carousel-arrow-{{ ai_gen_id }} ai-carousel-arrow-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-carousel-arrow-{{ ai_gen_id }} ai-carousel-arrow-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      <div class="ai-carousel-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</image-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoAdvanceInterval = null;
        this.autoAdvanceDelay = {{ block.settings.auto_advance_delay | times: 1000 }};
      }

      connectedCallback() {
        this.slidesContainer = this.querySelector('.ai-carousel-slides-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-carousel-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-carousel-arrow-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-carousel-dots-{{ ai_gen_id }}');

        if (this.slides.length <= 1) return;

        this.createDots();
        this.setupEventListeners();
        this.startAutoAdvance();
      }

      createDots() {
        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-carousel-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          if (index === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
        this.dots = this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.previousSlide());
        this.nextButton.addEventListener('click', () => this.nextSlide());

        this.addEventListener('mouseenter', () => this.stopAutoAdvance());
        this.addEventListener('mouseleave', () => this.startAutoAdvance());
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateCarousel();
        this.resetAutoAdvance();
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateCarousel();
        this.resetAutoAdvance();
      }

      previousSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateCarousel();
        this.resetAutoAdvance();
      }

      updateCarousel() {
        const offset = -this.currentSlide * 100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoAdvance() {
        if (this.autoAdvanceDelay > 0) {
          this.autoAdvanceInterval = setInterval(() => {
            this.nextSlide();
          }, this.autoAdvanceDelay);
        }
      }

      stopAutoAdvance() {
        if (this.autoAdvanceInterval) {
          clearInterval(this.autoAdvanceInterval);
          this.autoAdvanceInterval = null;
        }
      }

      resetAutoAdvance() {
        this.stopAutoAdvance();
        this.startAutoAdvance();
      }

      disconnectedCallback() {
        this.stopAutoAdvance();
      }
    }

    customElements.define('image-carousel-{{ ai_gen_id }}', ImageCarousel{{ ai_gen_id }});
  })();
</script>

