{{ 'component-material.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
  }
 
  @media screen and (min-width: 1199px) { 
  .shop_material_wrapper {
    grid-template-columns: repeat( {{ section.settings.columns_desktop }} , 1fr); 
}
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

{%- endstyle -%}
   <!-- start: Material Section -->
   <section class="about-material-section section-{{ section.id }}-padding color-{{ section.settings.section_color_scheme }}">
    <div class="page-width">
       <div class="heading-area">
          <h5 class="material_title">{{ settings.block.section_title }}</h5>
       </div>
       <div class="material_main_wrapper">
        {%- for block in section.blocks -%}
          <div class="material_item">
             <div class="material_icons">
                    {%- if block.settings.material_image != blank -%}
                      {{ block.settings.material_image | image_url: width: 1500 | image_tag: widths: '165, 360, 535, 750, 1070, 1500' }}
                      {%- else -%}
                      {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                      {%- assign placeholder_image = 'material-apparel-' | append: placeholder_image_index -%}
                      {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
             </div>
             <h5 class="material_item_title">
                {%- if block.settings.material_heading != blank -%}
                {{ block.settings.material_heading }}
              {%- else -%}
              Material Name
               {%- endif -%}
               </h5>
          </div>
        {% endfor %}
       </div>
    </div>
 </section>
 <!-- end: Material Section -->

{% schema %}
{
  "name": "All Material",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "section_title",
      "default": "Section Description",
      "label": "Section Description"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "t:sections.material-list.settings.columns_desktop.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 360,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 352
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 360,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 352
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material Section",
      "settings": [
        {
          "type": "image_picker",
          "id": "material_image",
          "label": "Material Image"
        },
        {
          "type": "text",
          "id": "material_heading",
          "label": "Heading",
          "info": "If left blank, the material name will be used."
        },
        {
          "type": "url",
          "id": "material_button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "All Material",
      "blocks": [
        {
          "type": "material"
        },
        {
          "type": "material"
        },
        {
          "type": "material"
        },
        {
          "type": "material"
        }
      ]
    }
  ]
}
{% endschema %}
 