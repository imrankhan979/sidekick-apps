{% doc %}
  @prompt
    Create a hero section with a background video for maximum impact. Include:- Headline: A powerful statement (max 10 words), e.g. "Experience the World Like Never Before"- Subheading: Brief supporting text, e.g. "Discover products crafted for those who dare to live boldly. Your next adventure starts here."- Background Video: Auto-plays silently (muted, loop, autoplay), MP4 format, 15-30 seconds, cinematic lifestyle style- Fallback Image: Static full-width image when video cannot play- CTA Button: "Shop the Collection" linking to a collection- Full-viewport height layout with video filling entire background- Dark overlay on video for text readability- Text and CTA centered with strong visual hierarchy- Smooth fade-in animation for headline and CTA on load
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 500px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-video-hero__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-video-hero__video-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
  }

  .ai-video-hero__fallback-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-hero__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-video-hero__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    color: {{ block.settings.text_color }};
    max-width: {{ block.settings.content_max_width }}px;
    padding: 0 20px;
    opacity: 0;
    animation: ai-video-hero-fade-in-{{ ai_gen_id }} 1s ease-out forwards;
    animation-delay: 0.3s;
  }

  @keyframes ai-video-hero-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-video-hero__headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.2;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-video-hero__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.5;
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.9;
  }

  .ai-video-hero__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    opacity: 0;
    animation: ai-video-hero-fade-in-{{ ai_gen_id }} 1s ease-out forwards;
    animation-delay: 0.6s;
  }

  .ai-video-hero__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-video-hero-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}vh;
      min-height: 400px;
    }

    .ai-video-hero__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-video-hero__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-video-hero__cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<video-hero-{{ ai_gen_id }} class="ai-video-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-hero__background-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      <video
        class="ai-video-hero__video-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
        {% if block.settings.fallback_image %}
          poster="{{ block.settings.fallback_image | image_url: width: 2000 }}"
        {% endif %}
      >
        <source src="{{ block.settings.video_url }}" type="video/mp4">
        {% if block.settings.fallback_image %}
          <img
            src="{{ block.settings.fallback_image | image_url: width: 2000 }}"
            alt="{{ block.settings.fallback_image.alt | escape }}"
            class="ai-video-hero__fallback-image-{{ ai_gen_id }}"
            loading="eager"
          >
        {% endif %}
      </video>
    {% elsif block.settings.fallback_image %}
      <img
        src="{{ block.settings.fallback_image | image_url: width: 2000 }}"
        alt="{{ block.settings.fallback_image.alt | escape }}"
        class="ai-video-hero__fallback-image-{{ ai_gen_id }}"
        loading="eager"
        width="{{ block.settings.fallback_image.width }}"
        height="{{ block.settings.fallback_image.height }}"
      >
    {% else %}
      <div class="ai-video-hero__fallback-image-{{ ai_gen_id }}" style="background-color: #000000;">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-video-hero__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-video-hero__content-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-video-hero__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-video-hero__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    {% if block.settings.cta_text != blank %}
      <a href="{{ block.settings.cta_link }}" class="ai-video-hero__cta-{{ ai_gen_id }}">
        {{ block.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</video-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.video = this.querySelector('.ai-video-hero__video-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.video) {
          this.ensureVideoPlays();
          this.handleVisibilityChange();
        }
      }

      ensureVideoPlays() {
        const playPromise = this.video.play();

        if (playPromise !== undefined) {
          playPromise.catch(() => {
            this.video.muted = true;
            this.video.play();
          });
        }
      }

      handleVisibilityChange() {
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            this.video.pause();
          } else {
            this.video.play();
          }
        });
      }
    }

    customElements.define('video-hero-{{ ai_gen_id }}', VideoHero{{ ai_gen_id }});
  })();
</script>

